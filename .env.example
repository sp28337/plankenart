# ─── Серверные переменные (ПРИВАТНЫЕ) ─────────────────────────────────────────
# Без префикса PUBLIC_ — никогда не попадут в браузер.
# Используются только в src/pages/api/contact.ts (серверный endpoint)

API_BASE_URL=https://your-backend.example.com
NOTIFY_TEST_PATH=/api/notify/test
NOTIFY_CALC_PATH=/api/notify/calc
PUBLIC_ENV=development
PUBLIC_ROBOTS_POLICY=disallow
KEYSTATIC_GITHUB_CLIENT_ID=...
KEYSTATIC_GITHUB_CLIENT_SECRET=...
KEYSTATIC_SECRET=$(openssl rand -hex 32) 

# ─── Публичные переменные (если нужны в компонентах) ──────────────────────────
# PUBLIC_ROBOTS_POLICY=allow

# ─── Примечание по адаптеру ───────────────────────────────────────────────────
# Endpoint src/pages/api/contact.ts требует серверного рендеринга.
# Установите нужный адаптер под ваш хостинг:
#
#   Node.js (VPS/Docker):   npx astro add node
#   Vercel:                 npx astro add vercel
#   Netlify:                npx astro add netlify
#   Cloudflare Workers:     npx astro add cloudflare
#
# После установки адаптера astro.config.mjs обновится автоматически.
# Сам сайт остаётся статическим — prerender = false только у /api/contact.