---
import ServiceCard from "@components/ui/ServiceCard.astro";
import H2 from "@components/ui/H2.astro";
import mirka from "@assets/services/mirka.png";
import oil from "@assets/services/oil.png";
import color from "@assets/services/colors.png";
import drel from "@assets/services/drel.png";
import blueprint from "@assets/services/blueprint.png";
---

<section
  id="services"
  aria-labelledby="services-heading"
  class="flex flex-col gap-6 md:gap-10 lg:gap-14 w-full items-center"
>
  <div class="flex flex-col items-center gap-4 text-center max-w-3xl reveal">
    <H2 id="services-heading" title="Услуги" />
    <p class="text-foreground/70 text-sm md:text-[1.05rem] leading-relaxed">
      Берем на себя полный цикл работ: от подготовки древесины до финального
      монтажа на вашем объекте.
    </p>
  </div>
  <div
    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 w-full gap-4 lg:gap-8"
  >
    <ServiceCard
      imgVariant="1"
      img={mirka}
      number="01"
      title="Шлифовка древесины"
      content="Профессиональная двухэтапная шлифовка погонажных изделий. Идеально подготавливаем планкен, вагонку и террасную доску."
    />
    <ServiceCard
      imgVariant="2"
      img={oil}
      number="02"
      title="Защитное покрытие"
      content="Двухслойное нанесение масел OSMO для глубокой защиты и выразительной фактуры дерева. Долговечность премиум-класса."
    />
    <ServiceCard
      imgVariant="3"
      img={color}
      number="03"
      title="Цветовые выкрасы"
      content="Бесплатно предоставляем индивидуальные выкрасы любых оттенков. Помогаем дизайнерам и заказчикам сделать идеальный выбор."
    />

    <div class="contents lg:flex lg:col-span-3 lg:justify-center lg:gap-8">
      <div class="lg:w-[calc((100%-4rem)/3)]">
        <ServiceCard
          imgVariant="4"
          img={drel}
          number="04"
          title="Монтаж под ключ"
          content="Безупречная укладка террас, монтаж вентилируемых фасадов и интерьерных решений силами опытных мастеров."
        />
      </div>

      <div class="sm:col-span-2 flex justify-center lg:contents">
        <div class="w-full sm:w-[calc(50%-0.5rem)] lg:w-[calc((100%-4rem)/3)]">
          <ServiceCard
            imgVariant="5"
            img={blueprint}
            number="05"
            title="Консультация"
            content="Анализ вашего проекта: подбор материалов, крепежа, расчет нагрузок и стоимости. Развернуто ответим на все профильные вопросы."
          />
        </div>
      </div>
    </div>
  </div>
</section>
