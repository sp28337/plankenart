---
import Arrow from "./svg/arrow.astro";
import Svg from "./svg/Svg.astro";
import Button from "./ui/Button.astro";

export interface Props {
  type: "test" | "calc";
}
const { type } = Astro.props;

const title = type === "test" ? "Заказать выкрас" : "Заказать расчет";
const formId = type === "test" ? "testForm" : "calcForm";
---

<div
  class="h-full border border-nav/20 hover:border-nav/70 rounded-[25px] reveal text-card-foreground flex flex-col bg-background"
>
  <div class="flex flex-col space-y-1.5 p-6">
    <h3 class="text-2xl font-inter text-center font-bold text-foreground">
      {title}
    </h3>
  </div>

  <div class="p-6 pt-0 space-y-6 grow flex flex-col">
    <form
      id={formId}
      class="contact-form space-y-6 flex flex-col h-full"
      data-form-type={type}
      novalidate
    >
      <div class="grid grid-cols-1 gap-4 grow">
        {/* Имя */}
        <div>
          <label class="block text-md font-semibold text-foreground mb-2">
            Имя: <span class="text-red-600">*</span></label
          >
          <input
            type="text"
            name="name"
            autocomplete="given-name"
            placeholder="Ваше имя"
            required
            class="w-full px-4 py-2 border border-nav/20 hover:border-nav/50 rounded-xl bg-card text-foreground placeholder:text-foreground/50 focus:outline-none transition-all duration-300"
          />
          <p class="error-msg nameError mt-1 text-sm text-red-600 hidden"></p>
        </div>

        {/* Телефон */}
        <div>
          <label class="block text-md font-semibold text-foreground mb-2">
            Телефон: <span class="text-red-600">*</span></label
          >
          <input
            type="tel"
            name="phone"
            autocomplete="tel"
            placeholder="+7 (XXX) XXX-XX-XX"
            required
            class="w-full px-4 py-2 border border-nav/20 hover:border-nav/50 rounded-xl bg-card text-foreground placeholder:text-foreground/50 focus:outline-none transition-all duration-300"
          />
          <p class="error-msg phoneError mt-1 text-sm text-red-600 hidden"></p>
        </div>

        {
          type === "test" && (
            <>
              <div>
                <label class="block text-md font-semibold text-foreground mb-2">
                  {" "}
                  Артикул(ы) масла: <span class="text-red-600">*</span>
                </label>
                <input
                  type="text"
                  name="articles"
                  placeholder="Например: 3101, 3111"
                  required
                  class="w-full px-4 py-2 border border-nav/20 hover:border-nav/50 rounded-xl bg-card text-foreground placeholder:text-foreground/50 focus:outline-none transition-all duration-300"
                />
                <p class="error-msg oilArticleError mt-1 text-sm text-red-600 hidden" />
              </div>
              <div>
                <label class="block text-md font-semibold text-foreground mb-2">
                  {" "}
                  Сорт дерева: <span class="text-red-600">*</span>
                </label>
                <input
                  type="text"
                  name="wood_sort"
                  placeholder="Например: Лиственница"
                  required
                  class="w-full px-4 py-2 border border-nav/20 hover:border-nav/50 rounded-xl bg-card text-foreground placeholder:text-foreground/50 focus:outline-none transition-all duration-300"
                />
                <p class="error-msg wood_sortError mt-1 text-sm text-red-600 hidden" />
              </div>
            </>
          )
        }

        {
          type === "calc" && (
            <>
              <div>
                <label class="block text-md font-semibold text-foreground mb-2">
                  {" "}
                  Площадь обработки (м²): <span class="text-red-600">*</span>
                </label>
                <input
                  type="text"
                  name="area"
                  placeholder="Например: 50"
                  required
                  class="w-full px-4 py-2 border border-nav/20 hover:border-nav/50 rounded-xl bg-card text-foreground placeholder:text-foreground/50 focus:outline-none transition-all duration-300"
                />
                <p class="error-msg treatmentAreaError mt-1 text-sm text-red-600 hidden" />
              </div>
              <div>
                <label class="block text-md font-semibold text-foreground mb-2">
                  {" "}
                  Артикул масла (необязательно):
                </label>
                <input
                  type="text"
                  name="article"
                  placeholder="Например: 3101"
                  class="w-full px-4 py-2 border border-nav/20 hover:border-nav/50 rounded-xl bg-card text-foreground placeholder:text-foreground/50 focus:outline-none transition-all duration-300"
                />
                <p class="error-msg oilArticleError mt-1 text-sm text-red-600 hidden" />
              </div>
            </>
          )
        }
      </div>

      {/* Согласие */}
      <div class="mt-auto pt-6">
        <div class="flex items-center space-x-3">
          <input
            type="checkbox"
            name="consent"
            required
            class="custom-checkbox checked:bg-emerald-500 appearance-none h-8 w-8 shrink-0 relative
                  cursor-pointer border border-nav/20 hover:border-nav/70
                  rounded-lg transition-all duration-300 mt-1 bg-nav/10"
          />
          <label
            class="text-md text-foreground/90 leading-relaxed cursor-pointer"
            onclick={`document.querySelector('#${formId} input[name="consent"]').click()`}
          >
            Отправляя заявку, вы подтверждаете что ознакомлены <a
              rel="noopener noreferrer"
              target="_blank"
              class="hover:underline text-text-gradient-top"
              href="/privacy-policy"
              onclick="event.stopPropagation()"
              >с политикой конфиденциальности</a
            > и даёте <a
              rel="noopener noreferrer"
              target="_blank"
              class="text-text-gradient-top hover:underline"
              href="/user-agreement"
              onclick="event.stopPropagation()"
              >согласие на обработку персональных данных</a
            > согласно Федерального закона "О персональных данных" от 27.07.2006 N
            152-ФЗ <span class="text-red-600 text-md font-semibold">*</span>
          </label>
        </div>
        <p class="error-msg consentError mt-1 text-sm text-red-600 ml-6 hidden">
        </p>

        {/* Кнопка */}
        <div class="mt-6 flex justify-center w-full">
          <Button type="submit">
            <span class="uppercase font-bold text-gradient tracking-tighter"
              >Отправить заявку</span
            >
            <Svg viewBox="arrow" size="m"><Arrow /></Svg>
          </Button>
        </div>

        {/* Сообщение */}
        <div class="form-message hidden"></div>
      </div>
    </form>
  </div>
</div>

<script>
  import "../scripts/contactsForm/index.js";
</script>
