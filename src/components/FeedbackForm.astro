---
import Button from "./ui/Button.astro";
import Input from "./ui/Input.astro";
import DraftingCompass from "@assets/svg/drafting-compass.svg";
import Paintbrush from "@assets/svg/paintbrush.svg";

export interface Props {
  type: "test" | "calc";
  idPrefix?: string;
}
const { type, idPrefix = "" } = Astro.props;

const title = type === "test" ? "Заказать выкрас" : "Заказать расчет";
const formId = `${idPrefix}${type === "test" ? "testForm" : "calcForm"}`;
const consentId = `${formId}-consent`;

// Хелпер для ID ошибки — чтобы aria-describedby и сам элемент совпадали
const errId = (field: string) => `${formId}-${field}-error`;
---

<div
  class="h-full group border border-nav/30 p-1 md:p-2
         rounded-[25px] reveal flex mb-4"
>
  <div class="h-full bg-nav/10 
         rounded-[25px] reveal text-card-foreground flex
         flex-col shadow-xl/2 hover:shadow-xl/6">
    <span
      class="absolute hidden xs:block top-6 right-6 saturate-0 opacity-30 transition-all duration-300 group-hover:saturate-100 group-hover:opacity-100"
    >
      {type == "calc" ? <DraftingCompass /> : <Paintbrush />}
    </span>
  
    <div class="flex space-y-1.5 p-6 xs:mt-2 items-center mx-auto relative">
      <h3
        class="text-2xl xs:text-3xl font-inter text-center font-bold text-amber-fade 
              transition-color duration-300 tracking-tighter saturate-0 group-hover:saturate-100
              opacity-50 group-hover:opacity-100
              "
      >
        {title}
      </h3>
    </div>
  
    <div class="p-2 xs:p-6 pt-0 space-y-6 grow flex flex-col">
      <!--
        method="POST" + action="/api/contact" — форма работает даже без JS:
        при отключённом JS браузер сделает нативный POST к Astro endpoint.
      -->
      <form
        id={formId}
        method="POST"
        action="/api/contact"
        class="contact-form space-y-6 flex flex-col h-full"
        data-form-type={type}
        novalidate
      >
        <!--
          Скрытый input передаёт тип формы на сервер.
          JS тоже читает его из FormData — data-form-type на форме остаётся
          для клиентской валидации.
        -->
        <input type="hidden" name="formType" value={type} />
  
        <div class="grid grid-cols-1 gap-2 xs:gap-4 grow">
          {/* Имя */}
          <div>
            <Input
              label="Имя:"
              type="text"
              name="name"
              autocomplete="given-name"
              placeholder="Ваше имя"
              required
              errorId={errId("name")}
            />
            <p
              id={errId("name")}
              class="error-msg nameError mt-1 text-sm text-red-600 hidden"
              role="alert"
            >
            </p>
          </div>
  
          {/* Телефон */}
          <div>
            <Input
              label="Телефон:"
              type="tel"
              name="phone"
              autocomplete="tel"
              placeholder="+7 (XXX) XXX-XX-XX"
              required
              errorId={errId("phone")}
            />
            <p
              id={errId("phone")}
              class="error-msg phoneError mt-1 text-sm text-red-600 hidden"
              role="alert"
            >
            </p>
          </div>
  
          {
            type === "test" && (
              <>
                <div>
                  <Input
                    label="Артикул(ы) масла:"
                    type="text"
                    name="articles"
                    placeholder="Например: 3101, 3111"
                    required
                    errorId={errId("articles")}
                  />
                  <p
                    id={errId("articles")}
                    class="error-msg articlesError mt-1 text-sm text-red-600 hidden"
                    role="alert"
                  />
                </div>
  
                <div>
                  <Input
                    label="Сорт дерева:"
                    type="text"
                    name="wood_sort"
                    placeholder="Например: Лиственница"
                    required
                    errorId={errId("wood_sort")}
                  />
                  <p
                    id={errId("wood_sort")}
                    class="error-msg wood_sortError mt-1 text-sm text-red-600 hidden"
                    role="alert"
                  />
                </div>
              </>
            )
          }
  
          {
            type === "calc" && (
              <>
                <div>
                  <Input
                    label="Площадь обработки (м²):"
                    type="text"
                    name="area"
                    placeholder="Например: 50"
                    required
                    errorId={errId("area")}
                  />
                  <p
                    id={errId("area")}
                    class="error-msg areaError mt-1 text-sm text-red-600 hidden"
                    role="alert"
                  />
                </div>
  
                <div>
                  <Input
                    label="Артикул масла (необязательно):"
                    type="text"
                    name="article"
                    placeholder="Например: 3101"
                    errorId={errId("article")}
                  />
                  <p
                    id={errId("article")}
                    class="error-msg articleError mt-1 text-sm text-red-600 hidden"
                    role="alert"
                  />
                </div>
              </>
            )
          }
        </div>
  
        {/* Согласие */}
        <div class="mt-auto pt-2 xs:pt-6">
          <div class="flex items-center space-x-3 group">
            <Input
              id={consentId}
              type="checkbox"
              name="consent"
              required
              errorId={errId("consent")}
            />
  
            <label
              for={consentId}
              class="text-xs xs:text-sm text-foreground/90 leading-relaxed cursor-pointer font-medium"
            >
              Я ознакомлен(а) с
              <a
                rel="noopener noreferrer"
                target="_blank"
                class="hover:underline text-amber-fade hover:text-btn font-semibold"
                href="/legal/privacy-policy"
                data-stop-prop
              >
                Политикой конфиденциальности
              </a>{" "}
              и даю согласие на обработку моих персональных данных в соответствии с настоящим{" "}
              <a
                rel="noopener noreferrer"
                target="_blank"
                class="text-amber-fade hover:text-btn hover:underline font-semibold"
                href="/legal/consent"
                data-stop-prop
              >
                Согласием
              </a>{" "}
            </label>
          </div>
  
          <p
            id={errId("consent")}
            class="error-msg consentError mt-1 text-sm text-red-600 ml-6 hidden"
            role="alert"
          >
          </p>
  
          {/* Кнопка */}
          <div class="mt-6 flex justify-center w-full">
            <Button type="submit" variant="form">
              <span class="uppercase font-bold text-html tracking-tighter">
                Отправить заявку
              </span>
            </Button>
          </div>
  
          {/* Сообщение об успехе / ошибке */}
          <div class="form-message hidden"></div>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  import "@features/contact-form/init";
</script>
