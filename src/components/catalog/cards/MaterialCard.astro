---
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";
import { Image } from "astro:assets";
import Fence from "@assets/svg/fence.svg";
import Trees from "@assets/svg/trees.svg";

interface Props {
  material: CollectionEntry<"materials">;
}

const { material } = Astro.props;

const [woodTag, materialTag] = await Promise.all([
  getEntry(material.data.woodType),
  getEntry(material.data.materialType),
]);
---

<div
  class="material-card bg-nav/20 group flex flex-col hover:bg-nav/45
         active:scale-98 active:bg-nav/45
         overflow-hidden shadow-xl/2 rounded-[15px] reveal
         transition-all duration-300 no-underline md:rounded-[20px]"
  data-wood={woodTag?.id}
  data-material={materialTag?.id}
>
  <a href={`/materials/${material.id}/`} class="flex flex-col h-full group">
    <div class="flex items-center justify-center">
      <Image
        src={material.data.coverImage}
        alt={material.data.imageAlt ?? material.data.title}
        class="w-35 h-12.5 xs:w-50 xs:h-25 object-contain right-1 sm:right-2
                transition-all duration-300"
        loading="lazy"
        decoding="async"
        widths={[200, 400]}
        sizes="(max-width: 480px) 200px, 400px"
      />
    </div>

    <div class="px-2 xs:px-3 py-2 xs:py-2.5">
      <h3 class="sr-only">{material.data.title}</h3>

      <div class="flex items-center gap-1.5 text-[12px] font-semibold">
        <Trees class="w-4 h-4 shrink-0 pointer-events-none opacity-45" aria-hidden="true" />
        <i>{woodTag?.data.tag}</i>
      </div>

      <div class="flex items-center gap-1.5 text-[12px] font-semibold mb-0.5">
        <Fence class="w-4 h-4 shrink-0 pointer-events-none opacity-45" aria-hidden="true" />
        <i>{materialTag?.data.tag}</i>
      </div>
    </div>
  </a>
</div>