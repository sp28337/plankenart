---
import type { CollectionEntry } from "astro:content";
import { categoryBySlug } from "@domain/knowledge/categories";
import { Picture } from "astro:assets";

interface Props {
  article: CollectionEntry<"knowledge">;
  variant?: "default" | "column" | "tags";
}

const { article, variant = "default" } = Astro.props;
const { title, excerpt, category, publishDate, coverImage } = article.data;
const cat = categoryBySlug[category as keyof typeof categoryBySlug];

const formattedDate = new Date(publishDate).toLocaleDateString("ru-RU", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<article
  class="knowledge-card p-1 md:p-1.5 border hover:border-nav/70 transition-all items-between
         duration-300 border-nav/20 rounded-2xl h-fit sm:h-full reveal overflow-hidden
         w-full group flex flex-col justify-between"
>
  <a
    href={`/knowledge/${article.id}/`}
    class:list={[variant === "default" && "", "flex flex-col gap-2"]}
    data-category={category}
  >
    <!-- 
    <div class="relative h-48 overflow-hidden">
      <Picture
        src={coverImage}
        formats={["avif", "webp"]}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
    </div>
  -->
    <div class="relative flex-1">
      <div
        class="transition-all w-full
              duration-300
              group-hover:opacity-50
              group-hover:after:content-['Читать']
              group-hover:after:absolute
              group-hover:after:inset-0
              group-hover:after:flex
              group-hover:after:items-center
              group-hover:after:justify-center
              group-hover:after:text-html
              group-hover:after:text-3xl
              group-hover:after:font-bold
              group-hover:after:font-inter
              group-hover:active:after:scale-98"
      >
        <Picture
          src={coverImage}
          formats={["avif", "webp"]}
          alt={title}
          class="w-full aspect-3/2 object-cover transition-all
                  duration-300 rounded-2xl"
          loading="lazy"
          decoding="async"
          widths={[400, 900]}
          sizes="(max-width: 480px) 400px, 800px"
        />
      </div>
    </div>
    <div class="flex flex-col gap-3 p-2 flex-1">
      <div class="flex items-center gap-2">
        <span
          class="text-[0.7rem] font-bold uppercase tracking-wider
                bg-nav/15 text-foreground/70 px-2.5 py-1 rounded-lg"
        >
          {cat?.icon}
          {cat?.label}
        </span>
      </div>
      <h3
        class="text-[clamp(1rem,1.9vw,1.2rem)] font-semibold truncate text-foreground group-hover:text-line tracking-tighter transition-all duration-300 font-inter"
      >
        {title}
      </h3>
      <!-- <h3
        class="font-inter font-bold text-base leading-snug tracking-tight
              text-foreground group-hover:text-amber-fade transition-colors duration-300"
      >
        {title}
      </h3> -->

      <p class="text-sm text-foreground/60 leading-relaxed line-clamp-3 flex-1">
        {excerpt}
      </p>

      <div
        class="flex items-center justify-between mt-auto pt-2 border-t border-nav/10"
      >
        <time class="text-xs text-foreground/40" datetime={publishDate}>
          {formattedDate}
        </time>
      </div>
    </div>
  </a>
</article>
