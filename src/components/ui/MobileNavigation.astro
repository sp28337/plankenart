---
import { navLinks } from "../../lib/navigation";
import Button from "./Button.astro";

const links = navLinks;
const current = Astro.url.pathname;
---

<!-- Overlay -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 z-100 opacity-0
         pointer-events-none transition-opacity duration-300
         backdrop-blur-[10px] bg-black/70 lg:hidden"
  aria-hidden="true"
>
</div>

<!-- Drawer -->
<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  class="fixed top-26 w-full xs:w-auto xs:right-0 z-101 lg:hidden
         bg-bg-primary opacity-0 pointer-events-none transition-opacity duration-300"
>
  <nav aria-label="Меню навигации">
    <ul class="flex flex-col px-2 font-inter font-semibold gap-1">
      {
        links.map(({ href, label }) => (
          <li
            class:list={[
              "overflow-hidden bg-nav p-0.75 xs:w-56 h-12 rounded-[18px] flex justify-center",
              current.startsWith(href) ? "bg-btn/80" : "",
            ]}
          >
            <a
              href={href}
              aria-current={current.startsWith(href) ? "page" : undefined}
              class:list={[
                "menu-link flex items-center justify-center tracking-tight w-full",
                "rounded-[17px] text-xl active:scale-98 px-4",
                "transition-colors hover:bg-html/80 duration-300 hover:text-foreground",
                current.startsWith(href) ? "bg-btn/80" : "",
              ]}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="flex flex-col gap-1 mt-4 px-2">
    <Button
      modalTarget="modal-test"
      variant="menu"
    >
      <span
        class:list={[
          "menu-link flex items-center justify-center tracking-tight w-full",
          "rounded-[17px] text-xl active:scale-98 px-4 h-full",
          "transition-colors hover:bg-btn/80 duration-300",
        ]}
      >
        Заказать выкрас
      </span>
    </Button>
    <Button
      modalTarget="modal-calc"
      variant="menu"
    >
      <span
        class:list={[
          "menu-link flex items-center justify-center tracking-tight w-full",
          "rounded-[17px] text-xl active:scale-98 px-4 h-full",
          "transition-colors hover:bg-btn/80 duration-300",
        ]}
      >
        Заказать расчет
      </span>
    </Button>
  </div>
</div>

<script>
  const btn = document.getElementById("burger-btn")!;
  const menu = document.getElementById("mobile-menu")!;
  const overlay = document.getElementById("mobile-menu-overlay")!;
  const links = Array.from(menu.querySelectorAll<HTMLElement>(".menu-link"));

  const DURATION = 0;
  const EASING = `cubic-bezier(0.22, 1, 0.36, 1)`;

  let closeTimer: ReturnType<typeof setTimeout> | null = null;

  function resetLinks() {
    links.forEach((el) => {
      el.style.transform = "translateY(-110%)";
    });
  }

  function openMenu() {
    if (closeTimer) {
      clearTimeout(closeTimer);
      closeTimer = null;
    }

    resetLinks();
    menu.offsetHeight;

    menu.classList.remove("opacity-0", "pointer-events-none");
    menu.classList.add("opacity-100");
    menu.setAttribute("aria-hidden", "false");

    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.classList.add("opacity-100");

    links.forEach((el, i) => {
      el.style.animation = `menu-slide-down ${DURATION}ms ${EASING} ${i * DURATION}ms forwards`;
    });

    btn.setAttribute("aria-expanded", "true");
    btn.setAttribute("aria-label", "Закрыть меню");
    menu.querySelector("a")?.focus();
  }

  function closeMenu() {
    btn.setAttribute("aria-expanded", "false");
    btn.setAttribute("aria-label", "Открыть меню");

    menu.classList.add("opacity-0", "pointer-events-none");
    menu.classList.remove("opacity-100");

    overlay.classList.add("opacity-0", "pointer-events-none");
    overlay.classList.remove("opacity-100");

    menu.setAttribute("aria-hidden", "true");

    closeTimer = setTimeout(() => {
      resetLinks();
      closeTimer = null;
    }, DURATION);
  }

  function toggleMenu() {
    btn.getAttribute("aria-expanded") === "true" ? closeMenu() : openMenu();
  }

  btn.addEventListener("click", toggleMenu);
  overlay.addEventListener("click", closeMenu);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && btn.getAttribute("aria-expanded") === "true") {
      closeMenu();
      btn.focus();
    }
  });

  document.addEventListener("astro:before-swap", closeMenu);

  links.forEach((el) => {
    if (el.getAttribute("href")?.includes("#")) {
      el.addEventListener("click", closeMenu);
    }
  });
</script>
