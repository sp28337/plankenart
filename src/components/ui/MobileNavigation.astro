---
const links = [
  { href: "/about",    label: "О нас"    },
  { href: "/services", label: "Услуги"   },
  { href: "/catalog",  label: "Каталог"  },
  { href: "/objects",  label: "Объекты"  },
  { href: "/contacts", label: "Контакты" },
];

const current = Astro.url.pathname;
---

<!-- Overlay -->
<div
  id="mobile-menu-overlay"
  class="top-20 fixed inset-0 z-100 opacity-0 
  pointer-events-none transition-opacity duration-300 lg:hidden"
  aria-hidden="true"
></div>

<!-- Drawer -->
<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  class="fixed top-19 right-0 z-101 lg:hidden
         bg-bg-primary opacity-0 pointer-events-none
         transition-all duration-300 ease-out"
>
  <nav 
    aria-label="Меню навигации" 
    class="flex flex-col px-2 font-inter font-semibold gap-1"
  >
    {links.map(({ href, label }) => (
      <a
        href={href}
        aria-current={current.startsWith(href) ? "page" : undefined}
        class:list={[
          "flex items-center justify-center tracking-tight w-41 h-7.5",
          "transform-gpu will-change-transform backdrop-blur-xl rounded-xl",
          "transition-colors hover:bg-amber-fade duration-300 bg-nav",
        ]}
      >
        {label}
      </a>
    ))}
  </nav>
</div>

<script>
  const btn     = document.getElementById("burger-btn")!;
  const menu    = document.getElementById("mobile-menu")!;
  const overlay = document.getElementById("mobile-menu-overlay")!;

  function openMenu() {
    menu.setAttribute("aria-hidden", "false");
    menu.classList.remove("translate-y-[-8px]", "opacity-0", "pointer-events-none");
    menu.classList.add("translate-y-0", "opacity-100");

    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.classList.add("opacity-100");

    btn.setAttribute("aria-expanded", "true");
    btn.setAttribute("aria-label", "Закрыть меню");

    menu.querySelector("a")?.focus();
  }

  function closeMenu() {
    menu.setAttribute("aria-hidden", "true");
    menu.classList.add("translate-y-[-8px]", "opacity-0", "pointer-events-none");
    menu.classList.remove("translate-y-0", "opacity-100");

    overlay.classList.add("opacity-0", "pointer-events-none");
    overlay.classList.remove("opacity-100");

    btn.setAttribute("aria-expanded", "false");
    btn.setAttribute("aria-label", "Открыть меню");
  }

  function toggleMenu() {
    btn.getAttribute("aria-expanded") === "true" ? closeMenu() : openMenu();
  }

  btn.addEventListener("click", toggleMenu);
  overlay.addEventListener("click", closeMenu);

  // Закрыть по Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && btn.getAttribute("aria-expanded") === "true") {
      closeMenu();
      btn.focus(); // вернуть фокус на кнопку
    }
  });

  // Закрыть при переходе на другую страницу (View Transitions)
  document.addEventListener("astro:before-swap", closeMenu);
</script>