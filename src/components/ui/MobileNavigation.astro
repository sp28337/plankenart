---
import { navLinks } from "@config/navigation";
import { DraftingCompass, Paintbrush }from "@lucide/astro";

const links = navLinks;
const current = Astro.url.pathname;
---

<!-- Overlay -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 z-100 opacity-0
         pointer-events-none transition-opacity duration-300
         backdrop-blur-[10px] bg-black/70 lg:hidden"
  aria-hidden="true"
>
</div>

<!-- Drawer -->
<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  class="fixed top-30 w-full xs:w-auto xs:right-0 z-101 lg:hidden
         bg-bg-primary opacity-0 pointer-events-none transition-opacity duration-300"
>
  <nav aria-label="Меню навигации">
    <ul class="flex flex-col mx-2 font-inter font-semibold bg-nav/80 rounded-3xl">
      {
        links.map(({ href, label, SvgIcon }) => (
          <li
            class:list={[
              "overflow-hidden mb-0 m-1 last:mb-1  h-12 flex justify-center",
              "bg-html/10 rounded-lg hover:bg-btn/70 first:rounded-t-3xl last:rounded-b-3xl",
              current.startsWith(href) ? "bg-btn/80" : "",
            ]}
          >
            <a
              href={href}
              aria-current={current.startsWith(href) ? "page" : undefined}
              class:list={[
                "menu-link flex items-center justify-start tracking-tight w-full",
                "text-xl active:scale-98 px-4 group",
                "transition-colors  duration-300",
                current.startsWith(href) ? "bg-btn/80" : "",
              ]}
            >
              <div class="flex gap-4 items-center">
                { SvgIcon && <SvgIcon class="opacity-70 group-hover:opacity-100 group-hover:scale-110 transition-all duration-300"/>}
                {label}
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="flex flex-col mt-4 mx-2 bg-nav/80 rounded-3xl font-inter font-bold">
    <button
      data-modal-open="modal-test" 
      class="overflow-hidden mb-0 m-1 last:mb-1  h-12 flex justify-center bg-html/10 rounded-lg hover:bg-btn/70 first:rounded-t-3xl last:rounded-b-3xl bg-btn/80"
    >
      <span
        class:list={[
          "menu-link flex items-center justify-start tracking-tight w-full",
          "text-xl active:scale-98 px-4 group",
          "transition-colors  duration-300 cursor-pointer",
        ]}
      >
        <div class="flex gap-4 items-center">
          <Paintbrush class="opacity-70 group-hover:opacity-100 group-hover:scale-110 transition-all duration-300"/>
          <span>
            Заказать выкрас
          </span>
        </div>
      </span>
    </button>
    <button
      data-modal-open="modal-calc" 
      class="overflow-hidden mb-0 m-1 last:mb-1  h-12 flex justify-center bg-html/10 rounded-lg hover:bg-btn/70 first:rounded-t-3xl last:rounded-b-3xl bg-btn/80"

    >
      <span
        class:list={[
          "menu-link flex items-center justify-start tracking-tight w-full",
          "rounded-lg text-xl active:scale-98 px-4 h-full group",
          "transition-colors hover:bg-btn/80 duration-300 cursor-pointer",
        ]}
      >
        <div class="flex gap-4 items-center">
          <DraftingCompass class="opacity-70 group-hover:opacity-100 group-hover:scale-110 transition-all duration-300"/>
          <span>
            Заказать расчет
          </span>
        </div>
      </span>
    </button>
  </div>
</div>

<script>
  const btn = document.getElementById("burger-btn")!;
  const menu = document.getElementById("mobile-menu")!;
  const overlay = document.getElementById("mobile-menu-overlay")!;
  const links = Array.from(menu.querySelectorAll<HTMLElement>(".menu-link"));

  const DURATION = 0;
  const EASING = `cubic-bezier(0.22, 1, 0.36, 1)`;

  let closeTimer: ReturnType<typeof setTimeout> | null = null;

  function resetLinks() {
    links.forEach((el) => {
      el.style.transform = "translateY(-110%)";
    });
  }

  function openMenu() {
    if (closeTimer) {
      clearTimeout(closeTimer);
      closeTimer = null;
    }

    resetLinks();
    menu.offsetHeight;

    menu.classList.remove("opacity-0", "pointer-events-none");
    menu.classList.add("opacity-100");
    menu.setAttribute("aria-hidden", "false");

    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.classList.add("opacity-100");

    links.forEach((el, i) => {
      el.style.animation = `menu-slide-down ${DURATION}ms ${EASING} ${i * DURATION}ms forwards`;
    });

    btn.setAttribute("aria-expanded", "true");
    btn.setAttribute("aria-label", "Закрыть меню");
    menu.querySelector("a")?.focus();
  }

  function closeMenu() {
    btn.setAttribute("aria-expanded", "false");
    btn.setAttribute("aria-label", "Открыть меню");

    menu.classList.add("opacity-0", "pointer-events-none");
    menu.classList.remove("opacity-100");

    overlay.classList.add("opacity-0", "pointer-events-none");
    overlay.classList.remove("opacity-100");

    menu.setAttribute("aria-hidden", "true");

    closeTimer = setTimeout(() => {
      resetLinks();
      closeTimer = null;
    }, DURATION);
  }

  function toggleMenu() {
    btn.getAttribute("aria-expanded") === "true" ? closeMenu() : openMenu();
  }

  btn.addEventListener("click", toggleMenu);
  overlay.addEventListener("click", closeMenu);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && btn.getAttribute("aria-expanded") === "true") {
      closeMenu();
      btn.focus();
    }
  });

  document.addEventListener("astro:before-swap", closeMenu);

  links.forEach((el) => {
    if (el.getAttribute("href")?.includes("#")) {
      el.addEventListener("click", closeMenu);
    }
  });
</script>
