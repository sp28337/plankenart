---
import FeedbackForm from "@components/FeedbackForm.astro";
---

<!-- ─── Calc Modal ─────────────────────────────────────────── -->
<div
  id="modal-calc"
  role="dialog"
  aria-modal="true"
  aria-label="Заказать расчёт"
  aria-hidden="true"
  class="fixed inset-0 z-300 flex items-center justify-center p-4 overflow-auto
         opacity-0 pointer-events-none transition-opacity duration-300"
>
  <div
    class="modal-overlay fixed inset-0 backdrop-blur-[10px] bg-html"
    data-modal-id="modal-calc"
  ></div>
<div class="flex flex-col">
    <button
      class="modal-close z-20 w-10 h-10 flex items-center ml-auto
            justify-center rounded-full bg-white/10 hover:bg-white/25
            transition-colors duration-300 text-foreground cursor-pointer"
      data-modal-id="modal-calc"
      aria-label="Закрыть"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M1 1L17 17M17 1L1 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="relative z-10 w-full max-w-lg max-h-[90svh] scroll-hidden">
      <FeedbackForm type="calc" idPrefix="modal-" />
    </div>
  </div>
</div>

<!-- ─── Test Modal ─────────────────────────────────────────── -->
<div
  id="modal-test"
  role="dialog"
  aria-modal="true"
  aria-label="Заказать выкрас"
  aria-hidden="true"
  class="fixed inset-0 z-300 flex items-center justify-center p-4 overflow-auto
         opacity-0 pointer-events-none transition-opacity duration-300"
>
  <div
    class="modal-overlay fixed inset-0 backdrop-blur-[10px] bg-html"
    data-modal-id="modal-test"
  ></div>
  <div class="flex flex-col">
    <button
      class="modal-close z-20 w-10 h-10 flex items-center ml-auto
            justify-center rounded-full bg-white/10 hover:bg-white/25
            transition-colors duration-300 text-foreground cursor-pointer"
      data-modal-id="modal-test"
      aria-label="Закрыть"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M1 1L17 17M17 1L1 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="relative z-10 w-full max-w-lg max-h-[90svh] scroll-hidden">
      <FeedbackForm type="test" idPrefix="modal-" />
    </div>
  </div>
</div>

<script>
  function initModals() {
    function openModal(id: string) {
      const modal = document.getElementById(id);
      if (!modal) return;
      // Ensure reveal animations fire inside the modal
      modal.querySelectorAll<HTMLElement>('.reveal').forEach(el => el.classList.add('visible'));
      modal.classList.remove('opacity-0', 'pointer-events-none');
      modal.classList.add('opacity-100');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeModal(id: string) {
      const modal = document.getElementById(id);
      if (!modal) return;
      modal.classList.add('opacity-0', 'pointer-events-none');
      modal.classList.remove('opacity-100');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    // Open — event delegation so it works across view-transition navigations
    document.addEventListener('click', (e) => {
      const trigger = (e.target as Element).closest<HTMLElement>('[data-modal-open]');
      if (trigger) openModal(trigger.dataset.modalOpen!);
    });

    // Close via overlay or X button
    document.querySelectorAll<HTMLElement>('.modal-overlay, .modal-close').forEach(el => {
      el.addEventListener('click', () => closeModal(el.dataset.modalId!));
    });

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      ['modal-calc', 'modal-test'].forEach(closeModal);
    });
  }

  document.addEventListener('astro:page-load', initModals);
  initModals();
</script>