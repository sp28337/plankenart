---
interface Props {
  title: string;
  content: string;
  size: "s" | "m" | "l" | "xl" | "auto";
}
const { 
  title, 
  content,
  size,
  } = Astro.props;

const base = `flex flex-col gap-2 md:gap-4 material-gradient rounded-2xl md:rounded-4xl 
              px-4 py-8 md:px-8 md:py-12 shadow-xl/2 hover:shadow-xl/6 transition-all duration-700`;

const sizes = {
  s: "w-60 h-60",
  m: "w-65 h-65",
  l: "w-70 h-70",
  xl: "w-75 h-75",
  auto: "w-full h-full min-h-[150px] md:w-[clamp(10vw, 20vw, 30vw)]",
};

const classes = `${base} ${sizes[size]}`;
---
<li class={classes}>
  <h3 class="text-lg font-semibold tracking-tighter leading-5">
    {title}
  </h3>
  <p class="opacity-70 text-md tracking-tight leading-5 sm:leading-6">
    {content}
  </p>
</li>