---
interface Props {
  title: string;
  content: string;
  size: "s" | "m" | "l" | "xl";
}
const { 
  title, 
  content,
  size,
  } = Astro.props;

const base = "flex flex-col gap-4 material-gradient rounded-4xl px-8 py-12 shadow-xl/2";

const sizes = {
  s: "w-60 h-60",
  m: "w-65 h-65",
  l: "w-70 h-70",
  xl: "w-75 h-75",
};

const classes = `${base} ${sizes[size]}`;
---
<div 
  role="listitem"
  class={classes}
>
  <h4 class="text-lg font-semibold tracking-tighter leading-5">
    {title}
  </h4>
  <p class="opacity-70 text-md tracking-tight">
    {content}
  </p>
</div>