---
interface Props {
  href: string
  tag: string
}

const {
  href,
  tag,
} = Astro.props
---

<a
  href={href}
  class="inline-block text-[0.77rem] px-[0.7rem] py-1 rounded-xl font-medium 
          no-underline whitespace-nowrap border border-dashed border-border 
          hover:border-solid hover:border-line transition-all duration-300 "
>
  <span class="text-gradient font-black">
    {tag}
  </span>
</a>