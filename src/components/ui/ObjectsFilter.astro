---
import ObjectDropdown from "@components/ui/ObjectDropdown.astro";
import WoodDropdown from "@components/ui/WoodDropdown.astro";
import MaterialDropdown from "@components/ui/MaterialDropdown.astro";
---
<div class="relative z-99 border border-dashed border-border 
            rounded-[17px] md:rounded-[20px] gap-1 sm:gap-2
            mx-auto max-w-7xl h-fit md:h-12 lg:h-14 p-1 md:p-1.5 
            flex flex-col sm:flex-row items-center"
>
  <ObjectDropdown/>
  <WoodDropdown/>
  <MaterialDropdown/>
</div>
