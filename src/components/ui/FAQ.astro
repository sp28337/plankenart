---
import H2 from "./H2.astro";

const faqs = [
  {
    question: "Можно ли привезти свою доску на обработку?",
    answer:
      "Да, принимаем материал заказчика. Предварительно уточните объём и породу дерева.",
  },
  {
    question: "Какие породы вы обрабатываете?",
    answer:
      "Лиственница, сосна, ель, термоясень, термососна. При необходимости — другие породы по согласованию.",
  },
  {
    question: "Нужно ли обрабатывать тыльную сторону доски?",
    answer:
      "Для интерьерных применений — нет. Для наружных фасадов — настоятельно рекомендуем. Незащищённая тыльная сторона активно впитывает влагу, что приводит к короблению.",
  },
  {
    question: "Почему масло OSMO, а не лак или краска?",
    answer:
      "Лак образует плёнку, которая со временем трескается и шелушится — особенно на улице. OSMO проникает внутрь дерева, не создаёт плёнки, и при необходимости легко обновляется без полного снятия покрытия.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<section
  aria-labelledby="faq-heading"
  class="flex flex-col gap-6 md:gap-10 lg:gap-14 w-full items-center"
>
  <H2 id="faq-heading" title="Отвечаем на частые вопросы" />
  <div class="w-full flex flex-col gap-2 md:gap-6 reveal">
    {faqs.map((faq) => (
      <details class="group" name="faq">
        <summary
          class="text-amber-fade font-bold text-[16px] xs:text-[20px] sm:text-[24px]
                  md:text-[28px] lg:text-[32px] font-inter tracking-tighter
                  list-none cursor-pointer transition-all duration-300
                  hover:-translate-y-1"
        >
          <div class="flex justify-between w-full px-1 md:px-5">
            <span>{faq.question}</span>
            <span
              class="text-amber-fade transition-transform duration-300 group-open:rotate-90"
              aria-hidden="true"
            >
              ›
            </span>
          </div>
        </summary>
        <div
          class="overflow-hidden max-h-0 group-open:max-h-96
                  transition-all duration-300 ease-in-out"
        >
          <p class="px-1 pt-2 md:px-5 md:pt-5 text-foreground/70 text-[14px]
                    md:text-[18px] lg:text-xl leading-relaxed ">
            {faq.answer}
          </p>
        </div>
      </details>
      <hr class="border-line/30 group-open:hidden" />
    ))}
  </div>
</section>

<script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />