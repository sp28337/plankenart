---
import H2 from "./H2.astro";

const faqs = [
  {
    question: "Как сделать заказ?",
    answer:
      "Напишите нам в Телеграм или просто позвоните — наш инженер свяжется с вами в течение часа, проконсультирует по материалам и рассчитает стоимость работ под ключ.",
  },
  {
    question: "С какими породами древесины вы работаете?",
    answer:
      "Мы профессионально обрабатываем лиственницу, термоясень, сосну и ель. Вся древесина сертифицирована, проходит камерную сушку до оптимальной влажности и идеально подходит для фасадов и террас.",
  },
  {
    question: "Какова гарантия на монтажные работы?",
    answer:
      "Мы предоставляем гарантию до 3-х лет на все наши услуги по укладке и шлифовке. При соблюдении рекомендаций по уходу наши фасады и террасы служат десятилетиями.",
  },
  {
    question: "Почему вы рекомендуете натуральные масла OSMO?",
    answer:
      "OSMO — это премиальное немецкое масло. Оно не создает пленку, а глубоко проникает в поры древесины. Фасад или террасная доска дышит, не растрескивается со временем и абсолютно безопасна для людей и животных.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<section
  aria-labelledby="faq-heading"
  class="flex flex-col gap-6 md:gap-10 lg:gap-14 w-full items-center"
>
  <H2 id="faq-heading" title="Отвечаем на частые вопросы" />
  <div class="w-full flex flex-col gap-2 md:gap-6 reveal">
    {faqs.map((faq) => (
      <details class="group" name="faq">
        <summary
          class="text-gradient font-bold text-[16px] xs:text-[20px] sm:text-[24px]
                  md:text-[28px] lg:text-[32px] font-inter tracking-tighter
                  list-none cursor-pointer transition-all duration-250
                  hover:-translate-y-1"
        >
          <div class="flex justify-between w-full px-1 md:px-5">
            <span>{faq.question}</span>
            <span
              class="text-gradient transition-transform duration-250 group-open:rotate-90"
              aria-hidden="true"
            >
              ›
            </span>
          </div>
        </summary>
        <div
          class="overflow-hidden max-h-0 group-open:max-h-96
                  transition-all duration-250 ease-in-out"
        >
          <p class="px-1 pt-2 md:px-5 md:pt-5 text-foreground/70 text-[14px]
                    md:text-[18px] lg:text-xl leading-relaxed cursor-default">
            {faq.answer}
          </p>
        </div>
      </details>
      <hr class="border-line/30 group-open:hidden" />
    ))}
  </div>
</section>

<script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />