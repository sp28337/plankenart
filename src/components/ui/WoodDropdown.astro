---
import { getCollection } from "astro:content";
import Trees from "@assets/svg/trees.svg"
import X from "@assets/svg/x.svg"
import ChevronDown from "@assets/svg/chevron-down.svg"

const woodTypes = await getCollection("woodTypes");
---
<div class="relative flex h-full w-full" id="wood-dropdown">
  <span id="wood-listbox-label" class="sr-only">Фильтр по виду дерева</span>
  <button
    type="button"
    id="wood-btn"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-controls="wood-panel"
    aria-labelledby="wood-listbox-label wood-btn"
    class="w-full flex items-center gap-2.5 py-1.5 px-5.5 bg-nav rounded-xl md:rounded-[14px] lg:rounded-[17px]
            cursor-pointer transition-colors duration-300 hover:bg-amber-fade
            font-semibold tracking-tight text-sm"
  >
    <Trees class="w-5 h-5 shrink-0 pointer-events-none" />
    <span id="wood-label" class="flex-1 text-left truncate">
      Вид дерева
    </span>
    <ChevronDown
      id="wood-chevron"
      class="w-4 h-4 shrink-0 pointer-events-none transition-transform duration-200"
    />
  </button>
  <div
    id="wood-panel"
    role="listbox"
    aria-hidden="true"
    aria-labelledby="wood-listbox-label"
    class="absolute top-[calc(100%+2.9rem)] sm:top-[calc(100%+0.5rem)] md:top-[calc(100%+0.8rem)] left-0 w-full z-99
            opacity-0 pointer-events-none transition-opacity duration-200
            bg-bg-primary"
  >
    <div class="flex flex-col gap-1 font-semibold">
      {woodTypes.map(w => (
        <div class="overflow-hidden">
          <button type="button"
            id={`wood-option-${w.id}`}
            role="option"
            aria-selected="false"
            data-value={w.data.title}
            data-slug={w.id}
            data-group="wood"
            class="dd-item w-full lg:max-w-[70%] text-left px-5.5 rounded-xl cursor-pointer h-7.5
                    text-xs md:text-sm tracking-tight transform-gpu will-change-transform
                    transition-colors duration-300 hover:bg-amber-fade bg-nav flex items-center gap-3"
            style="transform:translateY(-110%)">
            <Trees class="w-4.5 h-4.5 shrink-0 pointer-events-none" />                
            {w.data.title}
          </button>
        </div>
      ))}
      <div class="overflow-hidden">
        <button 
          id="wood-option-reset"
          role="option"
          aria-selected="false"
          type="button" 
          data-value="" 
          data-slug="" 
          data-group="wood"
          class="dd-item w-full lg:max-w-[70%] text-left px-5.5 rounded-xl cursor-pointer h-7.5
                  text-xs md:text-sm tracking-tight transform-gpu will-change-transform
                  transition-colors duration-300 hover:bg-amber-fade bg-nav gap-3 flex items-center"
          style="transform:translateY(-110%)">
          <X class="w-4.5 h-4.5 shrink-0 pointer-events-none" />                
          <span>
            Сбросить фильтр
          </span>
        </button>
      </div>
    </div>
  </div>
  <input type="hidden" id="filter-wood" name="wood" value="" />
</div>