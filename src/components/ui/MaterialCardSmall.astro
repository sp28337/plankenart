---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets';

export interface Props {
  variant?: "decor" | "default" | "object" | "tags";
  route: string;
  title: string;
  img: ImageMetadata;
};

const {
  route,
  img,
  title,
  variant = "default",
} = Astro.props;

const variants = {
  default: "w-full",
  decor: "lg:max-w-[420px] px-2 sm:px-0 lg:px-2 w-full",
  object: "px-4 md:px-6 w-fit",
  tags: "px-4 md:px-6 w-full",
}

const base = `transition-all relative flex  justify-evenly duration-300
              shadow-xl/2 h-12.5 items-center bg-nav/20 rounded-[17px]
              font-semibold  group reveal hover:bg-nav/40`;
const classes = `${base} ${variants[variant]}`;
---
<a
  class={classes}
  href={route}
>
  <div class="relative overflow-visible">
    <h3 class:list={[
                "text-foreground shrink-0 transition-colors duration-300",
                "group-hover:text-amber-fade text-sm w-37 truncate",
              ]}>
      {
        (variant == "default"  || variant == "decor") && title 
      }
      {
        variant == "tags" && 
        <span>
          {title.split(" — ")[0]}
        </span>
        <br/> 
        <i class="text-foreground/50 text-sm font-normal group-hover:text-amber-fade transition-all duration-300 leading-1">
          {title.split(" — ")[1].toLowerCase()}
        </i>
      }
      {
        variant == "object" &&
        <span>{title.split(" — ")[0]}</span>
        <i
          class="absolute w-fit -bottom-3 right-10 text-foreground/50 text-sm font-normal group-hover:text-amber-fade transition-all duration-300"
        >
          {title.split(" — ")[1].toLowerCase()}
        </i>
      }
    </h3>
  </div>

  <Image
    src={img}
    alt=""
    class="w-30 h-12.5 md:w-37.5 md:h-15 object-contain right-1 sm:right-2
           transition-all duration-300"
    loading="eager"
    widths={[150, 300]}
    sizes="(max-width: 640px) 150px, 300px"
    aria-hidden="true"
  />
</a>