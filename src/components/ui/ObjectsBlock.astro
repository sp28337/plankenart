---
import { getCollection } from "astro:content";
import ObjectCardExtended from "@components/ui/ObjectCardExtended.astro";
import H2 from "./H2.astro";
import Button from "./Button.astro";

const allObjects = await getCollection("objects");
---

<section
  id="objects"
  aria-labelledby="objects-heading"
  class="flex flex-col gap-6 md:gap-10 lg:gap-14 w-full items-center"
>
  <H2 id="objects-heading" title="Реализованные объекты" />
  <div class="flex flex-col gap-6 justify-center items-center w-full">
    <div
      id="grid"
      class="grid gap-2
              grid-cols-1 grid-rows-4
              sm:grid-cols-2 sm:grid-rows-2 w-full"
    >
      {
        allObjects.map((o) => (
          <ObjectCardExtended variant="catalog" object={o} />
        ))
      }
    </div>
    <Button href="/objects" title="Посмотреть все" variant="catalog" />
  </div>
</section>
