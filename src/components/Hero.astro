---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Svg from "@components/svg/Svg.astro";
import Telegram from "@components/svg/telegram.astro";

export interface Props {
  title: string | [string, string] | [string, string, string];
  excerpt?: string;
  img: ImageMetadata;
  imgMobile: ImageMetadata;
}

const { title, excerpt, img, imgMobile } = Astro.props;

const imgClasses = `w-full object-cover rounded-b-[20px] lg:rounded-b-[30px]
                    h-[100svh] sm:h-[90svh] min-h-[400px] mx-auto max-w-500 lg:max-h-270`;

const wrapperClasses = `h-auto p-4 md:p-6 bg-nav rounded-[20px]
                        md:rounded-[30px] backdrop-blur-xl lg:max-w-190
                        flex flex-col  w-full gap-4`;

const isArray = Array.isArray(title);
---

<div class="w-full relative">
  <Image
    src={img}
    alt={isArray ? title.join(" ") : title}
    class=`${imgClasses} hidden sm:block`
    loading="eager"
    fetchpriority="high"
    widths={[1920]}
    sizes="100vw"
  />
  <Image
    src={imgMobile}
    alt=""
    aria-hidden="true"
    class=`${imgClasses} sm:hidden`
    loading="eager"
    fetchpriority="high"
    widths={[1920]}
    sizes="100vw"
  />
  <div class="absolute bottom-2 lg:bottom-4 px-2 lg:px-4 w-full">
    <div
      class="flex flex-col justify-between xl:items-end xl:flex-row
                max-w-7xl mx-auto items-start gap-2 xl:gap-0"
    >
      <div class={wrapperClasses}>
        <h1
          class="tracking-tighter text-[clamp(1.7rem,4.5vw,3.2rem)] font-bold
              leading-6 sm:leading-8 lg:leading-12"
        >
          {
            isArray && title.length === 2 ? (
              <>
                {title[0]}
                <br />
                {title[1]}
              </>
            ) : isArray && title.length === 3 ? (
              <>
                <span
                  class="
                  after:content-['Арт_—']
                  after:-ml-1
                "
                >
                  {title[0]}
                </span>
                <br />
                {title[1]}
                <br />
                {title[2]}
              </>
            ) : (
              title
            )
          }
        </h1>
        {
          excerpt && (
            <p class="text-sm font-normal md:text-lg leading-4 md:leading-6 text-white/80 max-w-[70%]">
              {excerpt}
            </p>
          )
        }
      </div>
      <a
        href="https://t.me/Spedd87"
        aria-label="Написать специалисту в Telegram"
        rel="noopener noreferrer"
        target="_blank"
        class="w-full lg:max-w-190 xl:w-auto flex justify-center items-center
               transition-colors duration-300 gap-4 rounded-[20px] h-12.5 font-medium
               bg-html text-foreground px-7.5 py-2.5 backdrop-blur-xl
               active:scale-98 hover:bg-btn"
      >
        <span>Написать специалисту</span>
        <Svg viewBox="tg" size="l">
          <Telegram />
        </Svg>
      </a>
    </div>
  </div>
</div>