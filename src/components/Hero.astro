---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Svg from "@components/svg/Svg.astro"
import Telegram from "@components/svg/telegram.astro";
export interface Props {
  imgClass?: "home" | "default";
  wrapperClass?: "home" | "catalog" | "default";
  title: string | [string, string];
  excerpt?: string;
  img: ImageMetadata;
}
const {
  imgClass = "default",
  wrapperClass = "default",
  title,
  excerpt,
  img,
} = Astro.props;


const imgBase = `w-full object-cover rounded-b-[20px] lg:rounded-b-[30px]`
const imgClasses = {
  default: "h-screen 2xs:h-[80vh] min-h-[400px] mx-auto max-w-500 lg:max-h-270",
  home: "",
  short: "",
}

const wrapperBase = `h-auto p-4 md:p-6 bg-nav rounded-[20px] 
                     md:rounded-[30px] backdrop-blur-xl lg:max-w-190
                     flex flex-col cursor-default w-full gap-4`
const wrapperClasses = {
  default: "",
  catalog: "",
  home: "",
  short: "",
}

const isArray = Array.isArray(title);
---

<div class="w-full relative" id="top">
  <Image
    src={img}
    alt="Фоновое фото главной страницы с примером готового объекта"
    class=`${imgBase} ${imgClasses[imgClass]}`
    loading="eager"
    widths={[400, 800, 1200, 1920]}
    sizes="100vw"
  />
  <div class="absolute bottom-2 lg:bottom-4 px-2 lg:px-4 w-full">
    <div class="flex flex-col justify-between xl:items-end xl:flex-row 
                max-w-7xl mx-auto items-start gap-2 xl:gap-0"
    >
      <div class=`${wrapperBase} ${wrapperClasses[wrapperClass]}`
      >
        <h1 class="tracking-tighter text-[clamp(1.7rem,4.5vw,3.2rem)] font-bold 
              leading-6 sm:leading-8 lg:leading-12">
          {isArray ? (
            <>{title[0]}<br/>{title[1]}</>
          ) : (
            title
          )}
        </h1>
        <p class="text-sm font-normal md:text-lg leading-4 md:leading-6 text-white/80 max-w-70%">
          {excerpt}
        </p>
      </div>
      <a
        href="https://t.me/Spedd87"
        aria-label="Связаться со специалистом через телеграм"
        class:list={[
          "w-full lg:max-w-190 xl:w-auto flex justify-center items-center transition-colors duration-300 gap-4", 
          "rounded-[20px] h-12.5 font-medium bg-html hover:bg-btn text-foreground group", 
          "px-7.5 py-2.5 backdrop-blur-xl active:scale-105",
        ]}
      >
        <span>Написать специалисту</span>
        <Svg viewBox="tg" size="l">
          <Telegram/>
        </Svg>
      </a>
    </div>
  </div>
</div>