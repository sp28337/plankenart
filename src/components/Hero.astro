---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Svg from "@components/svg/Svg.astro"
import Telegram from "@components/svg/telegram.astro";
export interface Props {
  variant?: "home" | "default";
  title: string | [string, string];
  excerpt?: string;
  img: ImageMetadata;
}
const {
  variant = "default",
  title,
  excerpt,
  img,
} = Astro.props;


const variants = {
  default: "h-[50svh] lg:h-[90svh] lg:max-h-225",
  home: "h-[90svh] lg:max-h-225 min-h-162.5 object-[60%_0%] sm:object-[0%_30%] mx-auto max-w-500",
  short: "",
}

const base = `w-full object-cover rounded-b-[20px] lg:rounded-b-[30px] transition-all duration-200`

const classes = `${base} ${variants[variant]}`

const isArray = Array.isArray(title);
---

<section class="w-full relative">
  <Image
    src={img}
    alt="Hero background"
    class={classes}
    loading="eager"
    widths={[400, 800, 1200, 1920]}
    sizes="100vw"
  />
  <div class="absolute bottom-2 lg:bottom-4 px-2 lg:px-4 w-full">
    <div class="flex flex-col justify-between xl:items-end xl:flex-row 
                max-w-7xl mx-auto items-start gap-2 xl:gap-0"
    >
      <div class="w-full h-auto p-3.75 md:px-7.5 md:py-5 bg-nav rounded-[20px] 
                  md:rounded-[30px] backdrop-blur-xl
                  lg:max-w-190 flex flex-col gap-4 cursor-default"
      >
      <h1 class="tracking-tighter text-[24px] sm:text-4xl lg:text-5xl font-bold 
            leading-6 sm:leading-8 lg:leading-12">
        {isArray ? (
          <>{title[0]}<br/>{title[1]}</>
        ) : (
          title
        )}
      </h1>
        <span class="text-sm font-normal md:text-lg leading-4 md:leading-6 text-white/80">
          {excerpt}
        </span>
      </div>
      {
        variant == "home" &&
        <a
          href="https://t.me/Spedd87"
          aria-label="Связаться со специалистом через телеграм"
          class:list={[
            "w-full lg:max-w-190 xl:w-auto flex justify-center items-center transition-colors duration-300 gap-4", 
            "rounded-[20px] h-12.5 font-medium bg-html hover:bg-btn text-foreground group", 
            "px-7.5 py-2.5 backdrop-blur-xl",
          ]}
        >
          <span>Написать специалисту</span>
          <Svg viewBox="tg" size="l">
            <Telegram/>
          </Svg>
        </a>
      }
    </div>
  </div>
</section>