---
import { getCollection } from "astro:content";
import H2 from "@components/common/H2.astro";
import Button from "@components/common/Button.astro";
import KnowledgeCard from "@components/catalog/cards/KnowledgeCard.astro";
import { KNOWLEDGE_CATEGORIES } from "@domain/knowledge/categories";

const allArticles = (await getCollection("knowledge"))
  .sort((a, b) => (a.data.sortOrder ?? 99) - (b.data.sortOrder ?? 99))
  .slice(0, 6);
---

<section
  aria-labelledby="knowledge-heading"
  class="flex flex-col gap-6 md:gap-10 lg:gap-14 w-full items-center"
>
  <H2 id="knowledge-heading" title="База знаний" />

  <div class="flex flex-col gap-6 max-w-3xl text-center reveal">
    <p class="text-foreground/70 -mt-4 text-sm md:text-base leading-relaxed">
      Рассказываем простым языком, как выбрать древесину, чем обработать фасад
      или террасу, какое масло использовать и каких ошибок избежать при монтаже.
    </p>
  </div>

  <!-- Category pills -->
  <div class="flex flex-wrap justify-center gap-2 reveal">
    {KNOWLEDGE_CATEGORIES.map((cat) => (
      <a
        href={`/knowledge/?category=${cat.slug}`}
        class="text-[0.77rem] px-3 py-1.5 font-bold bg-nav/15
               text-foreground/60 rounded-xl
               hover:text-amber-fade hover:bg-nav/30
               transition-all duration-300 whitespace-nowrap"
      >
        {cat.icon} {cat.label}
      </a>
    ))}
  </div>

  {allArticles.length > 0 ? (
    <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 w-full">
      {allArticles.map((article) => (
        <KnowledgeCard article={article} />
      ))}
    </div>
  ) : (
    <div class="flex flex-col items-center gap-4 py-12 reveal">
      <p class="text-foreground/50 text-center text-lg">
        Статьи скоро появятся — мы уже работаем над контентом
      </p>
    </div>
  )}

  {allArticles.length > 0 && (
    <Button href="/knowledge/" title="все статьи" variant="catalog" />
  )}
</section>
