---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { DraftingCompass, Paintbrush, Phone } from "@lucide/astro";

export interface Props {
  title: string | [string, string] | [string, string, string];
  excerpt?: string;
  img: ImageMetadata;
  imgMobile: ImageMetadata;
}

const { title, excerpt, img, imgMobile } = Astro.props;

const imgClasses = `w-full object-cover rounded-b-[20px] lg:rounded-b-[30px]
                    h-[100svh] sm:h-[90svh] min-h-[400px] mx-auto max-w-500 lg:max-h-270`;

const wrapperClasses = `h-auto p-4 md:p-6 bg-nav rounded-[20px]
                        md:rounded-[30px] backdrop-blur-xl lg:max-w-190
                        flex flex-col  w-full gap-4`;

const isArray = Array.isArray(title);
---

<div class="w-full relative">
  <Image
    src={img}
    alt={isArray ? title.join(" ") : title}
    class=`${imgClasses} hidden sm:block`
    loading="eager"
    fetchpriority="high"
    widths={[1920]}
    sizes="100vw"
  />
  <Image
    src={imgMobile}
    alt=""
    aria-hidden="true"
    class=`${imgClasses} sm:hidden`
    loading="eager"
    fetchpriority="high"
    widths={[1920]}
    sizes="100vw"
  />
  <div class="absolute bottom-2 lg:bottom-4 xl:bottom-8 px-2 lg:px-4 w-full">
    <div
      class="flex flex-col justify-between xl:flex-row
                max-w-[1640px] mx-auto items-start gap-2 xl:gap-0 xl:items-center"
    >
      <div class={wrapperClasses}>
        <h1
          class="tracking-tighter text-[clamp(1.7rem,4.5vw,3.2rem)] font-bold
              leading-6 sm:leading-8 md:leading-10 lg:leading-14"
        >
          {
            isArray && title.length === 2 ? (
              <>
                {title[0]}
                <br />
                {title[1]}
              </>
            ) : isArray && title.length === 3 ? (
              <>
                <span
                  class="
                  after:content-['Арт_—']
                  after:-ml-1
                "
                >
                  {title[0]}
                </span>
                <br />
                {title[1]}
                <br />
                {title[2]}
              </>
            ) : (
              title
            )
          }
        </h1>
        {
          excerpt && (
            <p class="text-sm font-normal md:text-lg leading-4 md:leading-6 text-white/80 md:max-w-[70%]">
              {excerpt}
            </p>
          )
        }
      </div>
      <div class="w-full flex flex-col gap-1 xl:w-auto lg:max-w-190 2xl:mr-25 bg-nav p-1 rounded-3xl backdrop-blur-xl">
        <a
          href="tel:+79525433716"
          aria-label="Позвоните нам по номеру +79525433716"
          rel="noopener noreferrer"
          class="w-full lg:max-w-190 xl:w-auto flex justify-center items-center group shadow-md
                 transition-colors duration-300 gap-4 rounded-[20px] h-12.5 hover:bg-btn
                 bg-html text-foreground px-2 sm:px-6 py-2.5 backdrop-blur-xl hover:text-html
                 active:scale-98"
        >
          <Phone
            stroke-width={2.5}
            class="text-foreground group-hover:text-html transition-all duration-300 group-hover:scale-110"
          />
          <span class="font-bold text-xl">+7 (952) 543 37 16</span>
        </a>
        <div class="flex gap-1 lg:max-w-190">
          <button
            data-modal-open="modal-test"
            tabindex={0}
            class="modal-test w-full lg:max-w-190 xl:w-auto flex justify-center items-center hover:text-html
                 transition-colors duration-300 gap-4 rounded-[20px] h-12.5 group
                 bg-html text-foreground px-2 sm:px-6 py-2.5 backdrop-blur-xl hover:bg-btn
                 active:scale-98 font-bold cursor-pointer shadow-md"
          >
            <Paintbrush
              stroke-width={2.5}
              class="text-foreground group-hover:text-html transition-all duration-300 group-hover:scale-110"
            />
            <div class="flex gap-2">
              <span class="hidden xs:block"> Заказать </span>
              <span class="capitalize xs:lowercase"> выкрас </span>
            </div>
          </button>
          <button
            data-modal-open="modal-calc"
            tabindex={0}
            class="modal-test w-full lg:max-w-190 xl:w-auto flex justify-center items-center hover:text-html
                  transition-colors duration-300 gap-4 rounded-[20px] h-12.5 group
                  bg-html text-foreground px-2 sm:px-6 py-2.5 backdrop-blur-xl hover:bg-btn
                  active:scale-98 font-bold cursor-pointer shadow-md"
          >
            <DraftingCompass
              stroke-width={2.5}
              class="text-foreground group-hover:text-html transition-all duration-300 group-hover:scale-110"
            />
            <div class="flex gap-2">
              <span class="hidden xs:block"> Заказать </span>
              <span class="capitalize xs:lowercase"> расчет </span>
            </div>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
