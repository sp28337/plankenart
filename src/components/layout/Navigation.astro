---
import { navLinks } from "@config/navigation";

const links = navLinks;
const current = Astro.url.pathname;
---

<nav
  aria-label="Основная навигация"
  class="font-inter font-semibold p-0.75 
  tracking-tight h-12.5 overflow-y-hidden scroll-hidden
  bg-nav backdrop-blur-xl rounded-[20px] translate-y-5 shadow-xl/7"
>
  <ul class="flex items-center justify-between gap-0.75 my-auto 
             h-full overflow-y-hidden scroll-hidden rounded-[20px]">
    {
      links.map(({ href, label }) => (
        <li
          class:list={[
            "py-2 lg:px-2 2lg:p-3 3lg:p-4 h-full rounded-[18px] flex items-center hover:bg-html/80 ",
            "transition-all duration-300 hover:text-foreground cursor-pointer",
            current.startsWith(href) ? "bg-btn/80" : "",
          ]}
        >
          <a
            href={href}
            aria-current={current.startsWith(href) ? "page" : undefined}
            class="whitespace-nowrap "
          >
            {label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
