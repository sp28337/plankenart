---
/**
 * CookieBanner.astro
 *
 * GDPR/152-FZ compliant cookie consent banner.
 * Blocks all non-necessary cookies (Yandex Metrika) until user gives explicit consent.
 * Features: Accept All, Reject All, granular settings with analytics toggle.
 */
---

<!-- Cookie Consent Banner -->
<div
  id="cookie-banner"
  role="dialog"
  aria-label="Настройки файлов cookie"
  aria-modal="false"
  class="fixed bottom-0 left-0 right-0 z-9999
         translate-y-full opacity-0 pointer-events-none
         transition-all duration-500 ease-out
         px-2 pb-2 sm:px-4 sm:pb-4"
>
  <div
    class="max-w-4xl mx-auto rounded-2xl bg-footer/95 backdrop-blur-xl
              border border-border/20 shadow-2xl overflow-hidden"
  >
    <!-- Main Banner -->
    <div id="cookie-banner-main" class="p-4 sm:p-6">
      <div class="flex flex-col gap-4">
        <!-- Icon + Text -->
        <div class="flex items-start gap-3">
          <span class="text-2xl mt-0.5 shrink-0" aria-hidden="true">🍪</span>
          <div class="flex flex-col gap-1.5">
            <h2
              class="text-white font-inter font-bold text-base sm:text-lg tracking-tight"
            >
              Мы используем файлы cookie
            </h2>
            <p class="text-white/70 text-xs sm:text-sm leading-relaxed">
              Мы используем файлы cookie для корректной работы сайта. С вашего
              согласия мы также используем аналитические cookie (Яндекс Метрика)
              для улучшения качества сервиса. Вы можете настроить предпочтения
              или отказаться от необязательных cookie. Подробнее в
              <a
                href="/legal/privacy-policy"
                class="underline underline-offset-2
                 text-btn-solid hover:text-white transition-colors duration-200"
                >политике конфиденциальности</a
              >.
            </p>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col xs:flex-row gap-2 sm:gap-3 ml-0 sm:ml-9">
          <button
            id="cookie-accept-all"
            class="px-5 py-2.5 rounded-xl font-bold text-sm
                   bg-btn-solid text-html
                   hover:brightness-110 active:scale-[0.97]
                   transition-all duration-200 cursor-pointer
                   order-1"
          >
            Принять все
          </button>
          <button
            id="cookie-reject-all"
            class="px-5 py-2.5 rounded-xl font-bold text-sm
                   bg-white/10 text-white border border-white/20
                   hover:bg-white/20 active:scale-[0.97]
                   transition-all duration-200 cursor-pointer
                   order-2"
          >
            Только необходимые
          </button>
          <button
            id="cookie-configure"
            class="px-5 py-2.5 rounded-xl text-sm
                   text-white/70 hover:text-white
                   transition-all duration-200 cursor-pointer
                   order-3 underline underline-offset-2"
          >
            Настроить
          </button>
        </div>
      </div>
    </div>

    <!-- Settings Panel (hidden by default) -->
    <div id="cookie-settings-panel" class="hidden border-t border-white/10">
      <div class="p-4 sm:p-6 space-y-4">
        <!-- Back button -->
        <button
          id="cookie-settings-back"
          class="flex items-center gap-1.5 text-sm text-white/60 hover:text-white
                 transition-colors duration-200 cursor-pointer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m15 18-6-6 6-6"></path>
          </svg>
          Назад
        </button>

        <h3
          class="font-inter font-bold text-white text-base sm:text-lg tracking-tight"
        >
          Настройка файлов cookie
        </h3>

        <!-- Necessary cookies (always on) -->
        <div
          class="flex items-center justify-between gap-4 p-3 sm:p-4 rounded-xl bg-white/5"
        >
          <div class="flex flex-col gap-1">
            <span class="text-white font-semibold text-sm">Необходимые</span>
            <span class="text-white/50 text-xs leading-relaxed">
              Необходимы для корректной работы сайта и сохранения пользовательских настроек.
            </span>
          </div>
          <div class="shrink-0">
            <div
              class="w-11 h-6 rounded-full bg-btn-solid/60 relative cursor-not-allowed"
            >
              <div
                class="absolute top-0.5 right-0.5 w-5 h-5 rounded-full bg-white shadow"
              >
              </div>
            </div>
          </div>
        </div>

        <!-- Analytics cookies (toggleable) -->
        <div
          class="flex items-center justify-between gap-4 p-3 sm:p-4 rounded-xl bg-white/5"
        >
          <div class="flex flex-col gap-1">
            <span class="text-white font-semibold text-sm">Аналитические</span>
            <span class="text-white/50 text-xs leading-relaxed">
              Яндекс Метрика — помогает нам анализировать посещаемость и
              улучшать сайт. Собирает обезличенные данные: тип устройства,
              страницы посещений, источник перехода, примерное местоположение (регион).
            </span>
          </div>
          <div class="shrink-0">
            <label
              class="relative inline-flex items-center cursor-pointer"
              for="analytics-toggle"
            >
              <input
                type="checkbox"
                id="analytics-toggle"
                class="sr-only peer"
              />
              <div
                class="w-11 h-6 rounded-full
                          bg-white/20 peer-checked:bg-btn-solid
                          transition-colors duration-200
                          after:content-[''] after:absolute after:top-0.5 after:left-0.5
                          after:bg-white after:rounded-full after:h-5 after:w-5
                          after:shadow after:transition-transform after:duration-200
                          peer-checked:after:translate-x-5"
              >
              </div>
            </label>
          </div>
        </div>

        <!-- Save button -->
        <div class="flex justify-end pt-2">
          <button
            id="cookie-save-settings"
            class="px-6 py-2.5 rounded-xl font-bold text-sm
                   bg-btn-solid text-html
                   hover:brightness-110 active:scale-[0.97]
                   transition-all duration-200 cursor-pointer"
          >
            Сохранить настройки
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import "@infrastructure/analytics/cookie-consent";
</script>
