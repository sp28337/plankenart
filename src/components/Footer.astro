---
import { Picture } from "astro:assets";
import logo from "@assets/logo.png";
import { footerLinks } from "../lib/navigation";

const links = footerLinks;
---

<footer
  class="bg-footer w-full h-fit relative z-97
pt-10 pb-4 sm:pb-6 px-2 lg:px-4"
>
  <div class="max-w-7xl flex flex-col gap-4 sm:gap-6 mx-auto px-4 2xl:px-0">
    <div
      class="flex flex-col gap-8 pt-4 text-sm font-medium sm:flex-row sm:justify-between"
    >
      <div class="flex flex-col gap-10 xs:flex-row sm:gap-30">
        <section id="footer-nav" class="flex flex-col gap-3 cursor-default">
          <h3 class="font-inter font-bold text-lg">Навигация</h3>
          <ul class="flex flex-col gap-2">
            {
              links.map(({ href, label }) => (
                <li>
                  <a
                    href={href}
                    class="flex gap-4 items-center w-full rounded-2xl group 
          transition-all duration-250 opacity-70 hover:opacity-100"
                  >
                    {label}
                  </a>
                </li>
              ))
            }
          </ul>
        </section>

        <section id="contacts" class="flex flex-col gap-3 cursor-default">
          <h3 class="font-inter font-bold text-lg">Контакты</h3>
          <div class="flex flex-col gap-2">
            <a
              href="tel:+79525433716"
              class="flex gap-4 items-center w-full rounded-2xl group
            transition-all duration-250 opacity-70 hover:opacity-100"
            >
              <span> +7 (952) 543 37 16 </span>
            </a>
            <a
              href="https://t.me/Spedd87"
              class="flex gap-4 w-full
            items-center rounded-2xl group
            transition-all duration-250 opacity-70 hover:opacity-100"
            >
              <span> Написать в Телеграм </span>
            </a>
            <a
              href="https://vk.ru/id511687461"
              class="flex gap-4
            items-center w-full rounded-2xl group
            transition-all duration-250 opacity-70 hover:opacity-100"
            >
              <span> Группа Вконтакте </span>
            </a>
            <a
              href="https://yandex.ru/maps/47/nizhny-novgorod/?indoorLevel=1&ll=44.002375%2C56.322055&mode=routes&rtext=~56.321766%2C43.997731&rtt=auto&ruri=~ymapsbm1%3A%2F%2Fgeo%3Fdata%3DCgg1Njk4MTE2NxJR0KDQvtGB0YHQuNGPLCDQndC40LbQvdC40Lkg0J3QvtCy0LPQvtGA0L7QtCwg0J7QutGC0Y_QsdGA0YzRgdC60LDRjyDRg9C70LjRhtCwLCAxIgoNrv0vQhV9SWFC&z=17"
              class="flex gap-4
              items-center w-full rounded-2xl group
              transition-all duration-250 opacity-70 hover:opacity-100"
            >
              <span> Нижний Новгород, Октябрьская д 1 </span>
            </a>
          </div>
        </section>
      </div>

      <a
        href="#top"
        id="footer-logo-link"
        class="flex items-center justify-center lg:-translate-x-10 active:-translate-y-4 transition-all duration-250"
      >
        <Picture
          src={logo}
          formats={["avif", "webp"]}
          alt="Логотип ПланкенАрт"
          class="size-40 object-contain mx-auto"
          loading="eager"
        />
      </a>
    </div>
    <hr class="border-line" />
    <div
      class="text-[12px] text-center flex flex-col gap-4 opacity-70
    sm:justify-between sm:flex-row-reverse sm:text-sm cursor-default"
    >
      <p>Наш сайт не осуществляет сбор персональных данных</p>
      <p>© 2026 ПланкенАрт</p>
    </div>
  </div>
</footer>
<script>
  function initFooterAnimation() {
    const logoLink = document.getElementById("footer-logo-link");
    if (!logoLink) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            setTimeout(() => {
              entry.target.classList.add("animate-footer-bounce");
            }, 800);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 },
    );

    observer.observe(logoLink);
  }

  document.addEventListener("astro:page-load", initFooterAnimation);
  // Initial call for the first load
  initFooterAnimation();
</script>
