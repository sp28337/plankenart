---
import MobileNavigation from "@components/ui/MobileNavigation.astro";
import Logo from "@components/ui/Logo.astro";
import Navigation from "@components/ui/Navigation.astro";
import ContactButtons from "@components/ui/ContactButtons.astro";
---
<header class="fixed top-0 w-full px-2 lg:px-4 z-100">
  <div class="max-w-7xl flex justify-between gap-6 mx-auto">

    <div class="flex lg:hidden w-full justify-between">
      <Logo />
      <ContactButtons variant="mobile" />
    </div>

    <div class="hidden lg:flex w-full justify-between">
      <Logo variant="desktop"/>
      <Navigation />
      <ContactButtons variant="desktop" />
    </div>

  </div>
</header>
<MobileNavigation/>