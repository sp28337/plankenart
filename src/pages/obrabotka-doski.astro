---
import Layout from "@layouts/Layout.astro";
import Hero from "@components/Hero.astro";
import heroImg from "@assets/services/oil.png";
import heroImgMobile from "@assets/services/oil.png";
import CheckIcon from "@components/svg/CheckIcon.astro";
import ContactButtons from "@components/ui/ContactButtons.astro";

const risks = [
  "Защищает от влаги — дерево перестаёт активно впитывать воду и набухать.",
  "Предотвращает растрескивание — натуральные масла и воски сохраняют эластичность волокон.",
  "Блокирует УФ-излучение — замедляет выгорание и серение на солнце.",
  "Сохраняет «дыхание» — дерево остаётся паропроницаемым, не преет под покрытием.",
  "Подчёркивает текстуру — натуральный рисунок дерева становится выразительнее.",
  "Безопасно — масла OSMO сертифицированы по европейским стандартам, безопасны для людей и животных.",
];

const steps = [
  {
    title: "Шаг 1. Грубая шлифовка и калибровка",
    text: "Перед нанесением масла доска должна быть идеально ровной и чистой. Мы используем калибровально-шлифовальный станок Beaver SR-RP 400: он выравнивает толщину доски, устраняет перепады и коробление после сушки, удаляет ворс, следы инструмента и неровности.",
  },
  {
    title: "Шаг 2. Финишная шлифовка",
    text: "После калибровки выполняем шлифовку более мелким абразивом. Она убирает риски от первого прохода и формирует гладкую поверхность для равномерного впитывания масла без пятен и полос.",
  },
  {
    title: "Шаг 3. Первый слой масла OSMO",
    text: "Наносим и тщательно втираем первый слой на лицевые стороны доски. Масло проникает в поры, насыщает волокна и формирует базовую защиту. Между слоями выдерживается технологическая пауза до полного высыхания.",
  },
  {
    title: "Шаг 4. Второй слой масла OSMO",
    text: "Второй слой закрепляет защиту и итоговый внешний вид. Для фасадной доски рекомендуем дополнительно обрабатывать тыльную сторону, чтобы исключить впитывание влаги с обратной стороны и коробление.",
  },
];

const trust = [
  "Профессиональный станок Beaver SR-RP 400 — стабильная геометрия и ровная поверхность промышленного уровня.",
  "Более 10 лет практики с маслами OSMO: знаем поведение составов на разных породах и в разные сезоны.",
  "Официальный дилер: используем только оригинальные продукты OSMO без аналогов и разбавителей.",
  "Полный цикл на одном производстве: от калибровки до финального слоя под контролем одной команды.",
];
---

<Layout
  pageTitle="Обработка доски маслом OSMO — профессиональная шлифовка и пропитка"
  pageDescription="Обработка доски маслом OSMO: двухэтапная шлифовка, двойное покрытие, защита от влаги и УФ. Расчёт стоимости по объёму, породе и артикулу масла."
  ogImg={heroImg.src}
>
  <Hero
    title="Обработка доски маслом OSMO"
    excerpt="Профессиональная шлифовка и масляная пропитка для долговечной защиты и красивого вида древесины. Двухэтапная подготовка поверхности + двойное покрытие маслом — всё на одном производстве."
    img={heroImg}
    imgMobile={heroImgMobile}
  />

  <main class="px-2 lg:px-4 text-foreground mt-8">
    <div class="max-w-7xl mx-auto flex flex-col gap-8 md:gap-12">
      <section class="material-gradient rounded-2xl p-5 md:p-8 reveal">
        <h2 class="text-2xl md:text-3xl font-semibold mb-4">Почему дерево без защиты — это риск</h2>
        <p class="text-base md:text-lg leading-relaxed">
          Древесина — живой материал. Без защитного покрытия она активно поглощает влагу, пересыхает, трескается и теряет внешний вид уже через один-два сезона. Особенно это критично для фасадных и террасных досок, постоянно находящихся под воздействием дождя, ультрафиолета и перепадов температуры.
        </p>
        <p class="text-base md:text-lg leading-relaxed mt-4">
          Масло OSMO — не краска и не лак: оно глубоко проникает в поры древесины и работает изнутри.
        </p>
        <ul class="mt-5 space-y-3">
          {risks.map((item) => (
            <li class="flex items-start gap-3">
              <span class="shrink-0 pt-1"><CheckIcon /></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <p class="mt-5 text-base md:text-lg leading-relaxed">
          В результате правильно обработанная доска служит десятилетиями без необходимости полной перекраски.
        </p>
      </section>

      <section class="reveal">
        <h2 class="text-2xl md:text-3xl font-semibold mb-4">Как мы обрабатываем доску</h2>
        <div class="grid gap-4 md:grid-cols-2">
          {steps.map((step) => (
            <article class="bg-white rounded-2xl p-5 border border-border/40 shadow-sm">
              <h3 class="text-xl font-semibold mb-2">{step.title}</h3>
              <p class="leading-relaxed">{step.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="material-gradient rounded-2xl p-5 md:p-8 reveal">
        <h2 class="text-2xl md:text-3xl font-semibold mb-4">Почему стоит доверить обработку нам</h2>
        <ul class="space-y-3">
          {trust.map((item) => (
            <li class="flex items-start gap-3">
              <span class="shrink-0 pt-1"><CheckIcon /></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="bg-white rounded-2xl p-5 md:p-8 border border-border/40 reveal">
        <h2 class="text-2xl md:text-3xl font-semibold mb-4">Стоимость услуги</h2>
        <p class="leading-relaxed mb-4">
          Стоимость обработки зависит от объёма партии, породы древесины и выбранного масла OSMO. Артикул влияет на цену существенно: разница между прозрачными составами и цветными тонировками может достигать 2–3 раз. Также учитываем, нужна ли обработка только лицевых сторон или также тыльной стороны (актуально для фасадов).
        </p>
        <p class="leading-relaxed mb-6">
          Чтобы рассчитать точную стоимость, сообщите объём партии, породу дерева и артикул масла OSMO. Если с артикулом ещё не определились — поможем подобрать подходящий вариант.
        </p>
        <p class="text-lg font-semibold mb-4">Напишите нам — расчёт пришлём в течение нескольких часов.</p>
        <ContactButtons />
      </section>
    </div>
  </main>
</Layout>
