---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Heading from "@components/ui/Heading.astro";
import Tag from "@components/ui/Tag.astro";
import { tagsDictionary } from "../../lib/mappers";

const allMaterials = await getCollection("materials");
const allObjects = await getCollection("objects");

const items = [...allMaterials, ...allObjects];
const uniqueTags = [...new Set(items.flatMap((item) => item.data.tags ?? []))];
const uniqueMaterialTypes = [...new Set(allMaterials.map((item) => item.data.materialType))];
const uniqueObjectTypes = [...new Set(allObjects.map((item) => item.data.objectType))];
const uniqueWoodTypes = [...new Set(allMaterials.map((item) => item.data.woodType))];
const allTags = [...uniqueTags, ...uniqueMaterialTypes, ...uniqueObjectTypes, ...uniqueWoodTypes];
---
<Layout
  pageTitle="Теги"
  pageDescription="Все теги сайта ПланкенАрт"
>
  <div class="w-full object-cover rounded-b-[20px] pt-28 lg:pt-36 pb-12
              lg:rounded-b-[30px] bg-nav/20">
    <Heading
      styles="capitalize mx-auto text-gradient"
      title="Теги"
      variant="h1"
    />
    <p class="text-foreground/30 text-center reveal">
      <b>Выберите интересующую тему</b>
    </p>
  </div>
  <div class="px-2 lg:px-4 min-h-[70svh]">
    <div class="my-10 max-w-7xl flex flex-col items-center mx-auto
                text-foreground gap-10 md:gap-18 lg:gap-22">
      <div class="flex flex-wrap gap-2 h-fit reveal">
        {allTags.map((tag) => (
          <Tag
            href={`/tags/${tagsDictionary[tag]}`}
            tag={tag}
            variant="alternative"
          />
        ))}
      </div>
    </div>
  </div>
</Layout>