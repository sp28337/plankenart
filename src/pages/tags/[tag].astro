---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import MaterialCardSmall from "@components/ui/MaterialCardSmall.astro";
import H2 from "@components/ui/H2.astro";
import ObjectCard from "@components/ui/ObjectCard.astro";
import Heading from "@components/ui/Heading.astro";
import { tagsDictionary } from "../../lib/mappers";
import { tagsTitleDictionary } from "../../lib/titleMappers";

export async function getStaticPaths() {
  const [allMaterials, allObjects] = await Promise.all([
    getCollection("materials"),
    getCollection("objects"),
  ]);

  const tags = [
    ...new Set(
      [...allMaterials, ...allObjects].flatMap((item) => item.data.tags ?? []),
    ),
  ];
  const materialTypes = [
    ...new Set(allMaterials.map((item) => item.data.materialType)),
  ];
  const objectTypes = [
    ...new Set([
      ...allObjects.flatMap((item) => item.data.objectTypes ?? []),
      ...allMaterials.flatMap((item) => item.data.objectTypes ?? []),
    ]),
  ];
  const woodTypes = [
    ...new Set(allMaterials.map((item) => item.data.woodType)),
  ];

  const uniqueTags = [
    ...new Set([...tags, ...materialTypes, ...objectTypes, ...woodTypes]),
  ].filter((tag) => tagsDictionary[tag] !== undefined);

  return uniqueTags.map((tag) => {
    const materials = allMaterials.filter(
      (item) =>
        (item.data.tags ?? []).includes(tag) ||
        (item.data.objectTypes ?? []).includes(tag) ||
        item.data.woodType === tag ||
        item.data.materialType === tag,
    );

    const objects = allObjects.filter(
      (item) =>
        (item.data.tags ?? []).includes(tag) ||
        (item.data.objectTypes ?? []).includes(tag) ||
        (item.data.woodTypes ?? []).includes(tag),
    );

    const url = tagsDictionary[tag];

    return {
      params: { tag: url },
      props: { materials, objects },
    };
  });
}

const { tag } = Astro.params;
const { materials, objects } = Astro.props;
const pageTitle = tagsTitleDictionary[tag] ?? tag;

import Fence from "@assets/svg/fence.svg";
import Scan from "@assets/svg/scan.svg";
import Button from "@components/ui/Button.astro";
---

<Layout
  pageTitle={pageTitle}
  pageDescription={`Все материалы и объекты по теме: ${pageTitle}`}
>
  <!-- Hero Section -->
  <div
    class="w-full relative overflow-hidden rounded-b-[25px] lg:rounded-b-[40px] pt-32 lg:pt-40 pb-16 lg:pb-20
           bg-nav/20"
  >
    <div
      class="absolute inset-0 pointer-events-none bg-[radial-gradient(ellipse_at_top,var(--color-html)_0%,transparent_70%)] opacity-40"
    >
    </div>
    <div
      class="relative z-10 max-w-4xl mx-auto px-4 text-center flex flex-col items-center reveal"
    >
      <Heading
        styles="capitalize mx-auto text-gradient mb-4 lg:mb-6"
        title={pageTitle}
        variant="h1"
      />
      <p
        class="max-w-xl mx-auto text-foreground/70 text-sm md:text-base leading-relaxed cursor-default"
      >
        Все объекты и материалы, связанные с тегом: <b class="text-foreground"
          >{pageTitle}</b
        >
      </p>
    </div>
  </div>

  <div class="px-2 lg:px-4 min-h-[70svh]">
    <div
      class="my-8 lg:my-12 mx-auto max-w-7xl flex flex-col items-center
           text-foreground gap-8 md:gap-12 lg:gap-16"
    >
      {
        materials.length > 0 && (
          <section class="w-full flex flex-col gap-6 md:gap-8 lg:gap-10 border border-nav/20 hover:border-nav/70 rounded-[20px] p-2 sm:p-4 md:p-8 lg:p-10 reveal transition-all duration-250">
            <div class="flex flex-row sm:items-center gap-4 pb-4 lg:pb-6">
              <div class="w-12 h-12 rounded-[14px] border border-nav/20 flex flex-col items-center justify-center shrink-0 text-foreground">
                <Fence class="w-5 h-5 opacity-70 reveal" />
              </div>
              <H2 title="Материалы" />
            </div>
            <ul class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-2 md:gap-4 w-full">
              {materials.map((material) => (
                <li>
                  <MaterialCardSmall
                    route={`/materials/${material.id}/`}
                    title={material.data.title}
                    img={material.data.coverImage}
                    variant="tags"
                  />
                </li>
              ))}
            </ul>
          </section>
        )
      }
      {
        objects.length > 0 && (
          <section class="w-full flex flex-col gap-6 md:gap-8 lg:gap-10 border border-nav/20 hover:border-nav/70 rounded-[20px] p-2 sm:p-4 md:p-8 lg:p-10 reveal transition-all duration-250 mb-8 lg:mb-12">
            <div class="flex flex-row sm:items-center gap-4 pb-4 lg:pb-6">
              <div class="w-12 h-12 rounded-[14px] border border-nav/20 flex flex-col items-center justify-center shrink-0 text-foreground">
                <Scan class="w-5 h-5 opacity-70 reveal" />
              </div>
              <H2 title="Объекты" />
            </div>
            <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2 md:gap-4 w-full">
              {objects.map((object) => (
                <li>
                  <ObjectCard object={object} />
                </li>
              ))}
            </ul>
          </section>
        )
      }
      <div class="w-full flex justify-start reveal">
        <Button href="/tags" title="Все теги" />
      </div>
    </div>
  </div>
</Layout>
