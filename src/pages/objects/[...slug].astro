---
import Layout from "@layouts/Layout.astro";
import Hero from "@components/Hero.astro";
import H2 from "@components/ui/H2.astro";
import Tag from "@components/ui/Tag.astro";
import {
  getCollection,
  getEntries,
  render,
  type CollectionEntry,
} from "astro:content";
import { Image } from "astro:assets";
import DiscountSlider from "@components/ui/DiscountSlider.astro";
import MaterialCardSmall from "@components/ui/MaterialCardSmall.astro";
import Heading from "@components/ui/Heading.astro";
import CheckIcon from "@components/svg/CheckIcon.astro";
import { tagsDictionary } from "../../lib/mappers";
interface Props {
  object: CollectionEntry<"objects">;
}

export async function getStaticPaths() {
  const allObjects = await getCollection("objects");

  return allObjects.map((object) => {
    return {
      params: { slug: object.id },
      props: { object },
    };
  });
}

const { object } = Astro.props;
const { Content } = await render(object);

const usedOils = object.data.usedOils
  ? await Promise.all(
      object.data.usedOils.map(async (item) => {
        const oilEntry = await getEntries([item.oil]);
        const oil = oilEntry[0];

        const selectedColors = oil.data.colors.filter((color) =>
          item.code.includes(color.code),
        );

        return {
          surface: item.surface,
          oil,
          colors: selectedColors,
        };
      }),
    )
  : [];

const materials = await getEntries(object.data.materials);

const allTags = [
  ...object.data.tags,
  ...object.data.materialTypes,
  ...object.data.woodTypes,
  ...object.data.objectTypes,
];
---

<Layout
  pageTitle={object.data.metaTitle}
  pageDescription={object.data.metaDescription}
  ogImg={object.data.heroImage.src}
>
  <article>
    <Hero
      title={object.data.title}
      excerpt={object.data.excerpt}
      img={object.data.heroImage}
      imgMobile={object.data.heroImageMobile}
    />
    <div class="px-2 lg:px-4 text-foreground mt-8">
      <div
        class="max-w-7xl flex flex-col items-center mx-auto gap-10 lg:gap-18"
      >
        <div class="w-full">
          <section class="flex flex-col justify-center items-center gap-2">
            <Heading styles="text-gradient" title="Теги" variant="h3" />
            <ul
              class="flex flex-wrap justify-center gap-2 h-fit mb-5 md:mb-10 lg:mb-14 reveal"
            >
              {
                allTags.map((tag) => (
                  <li class="flex">
                    <Tag
                      href={`/tags/${tagsDictionary[tag]}`}
                      tag={tag}
                      variant="alternative"
                    />
                  </li>
                ))
              }
            </ul>
          </section>

          <div class="flex flex-col gap-10 md:gap-18 lg:gap-22">
            <section
              class="flex flex-col gap-6 md:gap-10 lg:gap-14 cursor-default"
            >
              <H2 title="История объекта" page="object" />
              <div class="flex flex-col gap-2 w-full reveal">
                {
                  object.data.description
                    .split("\n\n")
                    .map((p) => p.trim() && <p>{p.trim()}</p>)
                }
                {object.data.conclusion && object.data.conclusion}
                <div class="text-foreground flex flex-col gap-2 reveal">
                  <Content />
                </div>
              </div>
            </section>

            {
              object.data.technicalFeatures && (
                <section class="flex flex-col gap-6 md:gap-10 lg:gap-14 items-center">
                  <H2 title="Технические особенности" />
                  <ul class="list-none flex flex-col md:w-full w-[94%]">
                    {object.data.technicalFeatures.map((feat) => (
                      <li
                        class="flex gap-3 items-center text-[0.93rem] leading-normal reveal
                                py-2 md:px-4 rounded-2xl hover:bg-nav/30 transition-all duration-250"
                      >
                        <CheckIcon />
                        <p class="">{feat}</p>
                      </li>
                    ))}
                  </ul>
                </section>
              )
            }

            {
              materials && (
                <section class="w-full flex flex-col items-center gap-6 md:gap-10 lg:gap-14">
                  <H2 title="Материалы" />
                  <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 w-full">
                    {materials.map((material) => (
                      <li>
                        <MaterialCardSmall
                          route={`/materials/${material.id}/`}
                          title={material.data.title}
                          img={material.data.coverImage}
                          variant="tags"
                        />
                      </li>
                    ))}
                  </ul>
                </section>
              )
            }

            {
              usedOils.length > 0 && (
                <section class="w-full flex flex-col items-center gap-6 md:gap-10 lg:gap-14 cursor-default">
                  <H2 title="Масло" />

                  <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 w-full">
                    {usedOils.map(({ oil, colors, surface }) => (
                      <li
                        class="flex flex-col gap-4 duration-250
                                 border  border-nav/20 hover:border-nav/70 rounded-[17px]
                                 reveal p-2"
                      >
                        {/* поверхность */}
                        {surface && <p class="text-sm opacity-70">{surface}</p>}

                        <div class="flex flex-col gap-4 w-full">
                          <h3
                            class="text-lg font-semibold items-center tracking-tighter 
                                     leading-5 flex flex-col p-2"
                          >
                            {oil.data.title}
                            <span class="font-normal text-foreground/50 text-sm">
                              {oil.data.titleRu}
                            </span>
                          </h3>
                          <Image
                            src={oil.data.coverImage}
                            alt={oil.data.title}
                            class="w-46 h-46 object-cover rounded-xl mx-auto"
                          />
                          <div class="flex flex-col gap-2">
                            {colors.map((color) => (
                              <div class="items-center flex gap-2 bg-nav/20 p-2 rounded-2xl">
                                <div class="w-12 h-12 rounded-xl overflow-hidden">
                                  <Image
                                    src={color.image}
                                    alt={`${color.name} (${color.code})`}
                                    class="w-full h-full object-cover rounded-xl"
                                  />
                                </div>

                                <div class="flex relative flex-col">
                                  <span class="text-md top-2 font-inter font-bold">
                                    {color.code}
                                  </span>

                                  <i class="text-sm text-foreground/50 text-center">
                                    {color.name}
                                  </i>
                                </div>
                              </div>
                            ))}
                          </div>
                        </div>
                      </li>
                    ))}
                  </ul>
                </section>
              )
            }

            {
              object.data.images.length > 0 && (
                <section class="flex flex-col gap-6 md:gap-10 lg:gap-14 w-full">
                  <H2 title="Фотографии проекта" page="object" />
                  <ul
                    class="grid grid-cols-1 sm:grid-cols-2 gap-2"
                    id="lightbox-gallery"
                  >
                    {object.data.images.map((img, i) => (
                      <li
                        class="rounded-2xl lg:rounded-3xl overflow-hidden border 
                            border-nav/20 p-2 group hover:border-nav/70 transition-all duration-250
                            cursor-zoom-in reveal "
                        data-lightbox-index={i}
                      >
                        <Image
                          src={img}
                          alt={`${object.data.title} — фото ${i + 1}`}
                          class="w-full aspect-3/2 object-cover transition-all duration-250 
                              group-hover:scale-101 rounded-2xl lg:rounded-3xl pointer-events-none
                              "
                          loading="lazy"
                          widths={[400, 900]}
                        />
                      </li>
                    ))}
                  </ul>
                </section>
              )
            }
          </div>
        </div>
        <div class="w-full flex flex-col items-center">
          <DiscountSlider />
        </div>
      </div>
    </div>
  </article>
</Layout>

{
  // image viewer
}
<div
  id="lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Просмотр фото"
  class="fixed inset-0 z-9999 flex items-center justify-center
         opacity-0 pointer-events-none
         bg-black/90
         transition-opacity duration-250"
>
  <button
    id="lb-close"
    aria-label="Закрыть"
    class="absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center
           rounded-full bg-white/10 hover:bg-white/25 transition-colors duration-250
           text-white cursor-pointer"
  >
    <svg
      width="18"
      height="18"
      viewBox="0 0 18 18"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M1 1L17 17M17 1L1 17"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"></path>
    </svg>
  </button>

  <img
    id="lb-img"
    src=""
    alt=""
    class="w-full h-full object-contain select-none transition-opacity duration-250"
    draggable="false"
  />

  <div
    id="lb-spinner"
    class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-0 transition-opacity duration-250"
  >
    <div
      class="w-10 h-10 rounded-full border-2 border-white/30 border-t-white animate-spin"
    >
    </div>
  </div>
</div>

<script>
  const btnClose = document.getElementById("lb-close")!;
  const gallery = document.getElementById("lightbox-gallery");
  const lightbox = document.getElementById("lightbox")!;
  const lbImg = document.getElementById("lb-img") as HTMLImageElement;
  const lbSpinner = document.getElementById("lb-spinner")!;

  if (!gallery) throw new Error("gallery not found");

  const items = Array.from(
    gallery.querySelectorAll<HTMLLIElement>("[data-lightbox-index]"),
  );
  const srcs = items.map((li) => li.querySelector("img")!.src);

  let current = 0;
  let isOpen = false;
  let loadingTimer: ReturnType<typeof setTimeout> | null = null;

  // touch state
  let touchStartX = 0;
  let touchDeltaX = 0;
  let isPinching = false;

  function loadImage(index: number, _instant = false) {
    // если уже закешировано браузером — покажем сразу без мигания
    const probe = new window.Image();
    probe.src = srcs[index];

    if (probe.complete) {
      // картинка уже в кеше
      lbImg.src = srcs[index];
      lbImg.style.opacity = "1";
      lbSpinner.style.opacity = "0";
      return;
    }

    // картинка ещё грузится — показываем спиннер с небольшой задержкой
    // чтобы не мелькал при быстрой загрузке
    lbImg.style.opacity = "0";
    loadingTimer = setTimeout(() => {
      lbSpinner.style.opacity = "1";
    }, 150);

    probe.onload = () => {
      if (loadingTimer) clearTimeout(loadingTimer);
      lbImg.src = srcs[index];
      lbImg.alt = `Фото ${index + 1}`;
      lbImg.style.opacity = "1";
      lbSpinner.style.opacity = "0";
    };

    probe.onerror = () => {
      if (loadingTimer) clearTimeout(loadingTimer);
      lbSpinner.style.opacity = "0";
      lbImg.style.opacity = "1";
    };
  }

  function open(index: number) {
    current = index;
    isOpen = true;
    document.body.style.overflow = "hidden";
    lightbox.classList.remove("opacity-0", "pointer-events-none");
    lightbox.classList.add("opacity-100");
    lightbox.removeAttribute("aria-hidden");
    loadImage(index);
  }

  function close() {
    isOpen = false;
    if (loadingTimer) clearTimeout(loadingTimer);
    lbSpinner.style.opacity = "0";
    document.body.style.overflow = "";
    lightbox.classList.add("opacity-0", "pointer-events-none");
    lightbox.classList.remove("opacity-100");
    lightbox.setAttribute("aria-hidden", "true");
  }

  function prev() {
    if (current > 0) open(current - 1);
  }
  function next() {
    if (current < srcs.length - 1) open(current + 1);
  }

  items.forEach((li, i) => li.addEventListener("click", () => open(i)));

  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) close();
  });
  btnClose.addEventListener("click", close);

  document.addEventListener("keydown", (e) => {
    if (!isOpen) return;
    if (e.key === "Escape") close();
    if (e.key === "ArrowLeft") prev();
    if (e.key === "ArrowRight") next();
  });

  lightbox.addEventListener(
    "touchstart",
    (e) => {
      if (e.touches.length >= 2) {
        isPinching = true;
        touchDeltaX = 0;
      } else if (!isPinching) {
        touchStartX = e.touches[0].clientX;
        touchDeltaX = 0;
      }
    },
    { passive: true },
  );

  lightbox.addEventListener(
    "touchmove",
    (e) => {
      if (e.touches.length >= 2) {
        isPinching = true;
        touchDeltaX = 0;
        return;
      }
      if (isPinching) return;
      touchDeltaX = e.touches[0].clientX - touchStartX;
    },
    { passive: true },
  );

  lightbox.addEventListener("touchend", (e) => {
    if (e.touches.length > 0) {
      touchDeltaX = 0;
      return;
    }
    if (isPinching) {
      isPinching = false;
      touchDeltaX = 0;
      return;
    }
    if (touchDeltaX < -60) next();
    else if (touchDeltaX > 60) prev();
    touchDeltaX = 0;
  });
</script>
