---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import H2 from '@components/ui/H2.astro';
import Tag from '@components/ui/Tag.astro';
import { getCollection, getEntry, getEntries, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import DiscountSlider from '@components/ui/DiscountSlider.astro';
interface Props {
  object: CollectionEntry<'objects'>;
}

export async function getStaticPaths() {
  const allObjects = await getCollection('objects');
  return allObjects.map(object => ({
    params: { slug: object.id },
    props: { object },
  }));
}

const { object } = Astro.props;
const { Content } = await render(object);

const objectType    = await getEntry(object.data.objectType);
const materialTypes = await getEntries(object.data.materialTypes);
const woodTypes = await getEntries(object.data.woodTypes);
---

<Layout
  pageTitle={object.data.metaTitle}
  pageDescription={object.data.metaDescription}
>
  <article>
    <Hero
      title={object.data.title}
      excerpt={object.data.excerpt}
      img={object.data.heroImage}
    />
    <div class="px-2 lg:px-4 text-foreground mt-8 mb-8">
      <div class="max-w-7xl flex flex-col items-center mx-auto gap-10 lg:gap-18">
        <div class="w-full">
          <div class="flex flex-col gap-8">

            <div class="flex flex-wrap justify-center gap-2 h-fit reveal">
              <Tag href={`/objects?object=${objectType.id}`} tag={objectType.data.title} />
              {woodTypes.map(w => (
                <Tag href={`/objects?wood=${w.id}`} tag={w.data.title} />
              ))}
              {materialTypes.map(m => (
                <Tag href={`/objects?type=${m.id}`} tag={m.data.title} />
              ))}
            </div>


            <section class="flex flex-col gap-6 reveal">
              <H2 title="История объекта" page="object"/>
              <div class="flex flex-col gap-2 w-full">
                {object.data.description.split('\n\n').map(p =>
                  p.trim() && <p>{p.trim()}</p>
                )}
                <div class="text-foreground flex flex-col gap-2">
                  <Content />
                </div>
              </div>
            </section>


            {object.data.images.length > 0 && (
              <section class="flex flex-col gap-6 sm:gap-10 w-full reveal">
                <H2 title="Фотографии проекта" page="object"/>
                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 sm:gap-6" id="lightbox-gallery">
                  {object.data.images.map((img, i) => (
                    <li
                      class="rounded-2xl lg:rounded-3xl overflow-hidden border border-dashed
                            border-border p-2 group hover:border-solid transition-all duration-300
                            cursor-zoom-in"
                      data-lightbox-index={i}
                    >
                      <Image
                        src={img}
                        alt={`${object.data.title} — фото ${i + 1}`}
                        class="w-full aspect-3/2 object-cover transition-all duration-200 
                              group-hover:scale-101 rounded-2xl lg:rounded-3xl pointer-events-none
                              active:scale-115"
                        loading="lazy"
                        widths={[300, 500, 900]}
                        sizes="(max-width: 480px) 300px, 500px"
                      />
                    </li>
                  ))}
                </ul>
              </section>
            )}

          </div>
        </div>
        <div class="reveal w-full flex flex-col items-center">
          <DiscountSlider/>
        </div>
      </div>
    </div>
  </article>
</Layout>

<div
  id="lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Просмотр фото"
  class="fixed inset-0 z-9999 flex items-center justify-center
         opacity-0 pointer-events-none
         bg-black/80 backdrop-blur-sm
         transition-opacity duration-300"
>
  <button
    id="lb-close"
    aria-label="Закрыть"
    class="absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center
           rounded-full bg-white/10 hover:bg-white/25 transition-colors duration-200
           text-white cursor-pointer"
  >
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M1 1L17 17M17 1L1 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>

  <button
    id="lb-prev"
    aria-label="Предыдущее фото"
    class="absolute left-3 sm:left-6 z-10 w-10 h-10 flex items-center justify-center
           rounded-full bg-white/10 hover:bg-white/25 transition-colors duration-200
           text-white cursor-pointer disabled:opacity-20 disabled:cursor-default"
  >
    <svg width="10" height="17" viewBox="0 0 10 17" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M9 1L1 8.5L9 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <button
    id="lb-next"
    aria-label="Следующее фото"
    class="absolute right-3 sm:right-6 z-10 w-10 h-10 flex items-center justify-center
           rounded-full bg-white/10 hover:bg-white/25 transition-colors duration-200
           text-white cursor-pointer disabled:opacity-20 disabled:cursor-default"
  >
    <svg width="10" height="17" viewBox="0 0 10 17" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M1 1L9 8.5L1 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div
    id="lb-img-wrap"
    class="relative w-[80vw] h-[80vh] flex items-center justify-center"
  >
    <img
      id="lb-img"
      src=""
      alt=""
      class="max-w-full max-h-full object-contain rounded-xl select-none
             transition-opacity duration-200"
      draggable="false"
    />
    <div
      id="lb-spinner"
      class="absolute inset-0 flex items-center justify-center pointer-events-none"
    >
      <div class="w-8 h-8 rounded-full border-2 border-white/30 border-t-white animate-spin"></div>
    </div>
  </div>

  <div
    id="lb-counter"
    class="absolute bottom-4 left-1/2 -translate-x-1/2
           text-white/60 text-sm font-medium tabular-nums select-none"
  ></div>
</div>

<script>
  const gallery  = document.getElementById("lightbox-gallery");
  const lightbox = document.getElementById("lightbox")!;
  const lbImg    = document.getElementById("lb-img") as HTMLImageElement;
  const lbSpinner = document.getElementById("lb-spinner")!;
  const lbCounter = document.getElementById("lb-counter")!;
  const btnClose = document.getElementById("lb-close")!;
  const btnPrev  = document.getElementById("lb-prev") as HTMLButtonElement;
  const btnNext  = document.getElementById("lb-next") as HTMLButtonElement;

  if (!gallery) throw new Error("gallery not found");

  const items = Array.from(gallery.querySelectorAll<HTMLLIElement>("[data-lightbox-index]"));
  const srcs  = items.map(li => {
    const img = li.querySelector("img")!;
    return img.src;
  });

  let current = 0;
  let isOpen  = false;

  let touchStartX = 0;
  let touchDeltaX = 0;

  function updateButtons() {
    btnPrev.disabled = current === 0;
    btnNext.disabled = current === srcs.length - 1;
    lbCounter.textContent = `${current + 1} / ${srcs.length}`;
  }

  function loadImage(index: number) {
    lbImg.style.opacity = "0";
    lbSpinner.style.opacity = "1";

    const newImg = new window.Image();
    newImg.src = srcs[index];
    newImg.onload = () => {
      lbImg.src = srcs[index];
      lbImg.alt = `Фото ${index + 1}`;
      lbImg.style.opacity = "1";
      lbSpinner.style.opacity = "0";
    };
    newImg.onerror = () => {
      lbSpinner.style.opacity = "0";
    };
  }

  function open(index: number) {
    current = index;
    isOpen  = true;
    document.body.style.overflow = "hidden";
    lightbox.classList.remove("opacity-0", "pointer-events-none");
    lightbox.classList.add("opacity-100");
    lightbox.removeAttribute("aria-hidden");
    loadImage(current);
    updateButtons();
    btnClose.focus();
  }

  function close() {
    isOpen = false;
    document.body.style.overflow = "";
    lightbox.classList.add("opacity-0", "pointer-events-none");
    lightbox.classList.remove("opacity-100");
    lightbox.setAttribute("aria-hidden", "true");
  }

  function prev() {
    if (current > 0) {
      current--;
      loadImage(current);
      updateButtons();
    }
  }

  function next() {
    if (current < srcs.length - 1) {
      current++;
      loadImage(current);
      updateButtons();
    }
  }

  items.forEach((li, i) => {
    li.addEventListener("click", () => open(i));
  });

  btnClose.addEventListener("click", close);
  btnPrev.addEventListener("click", prev);
  btnNext.addEventListener("click", next);

  lightbox.addEventListener("click", e => {
    if (e.target === lightbox) close();
  });

  document.addEventListener("keydown", e => {
    if (!isOpen) return;
    if (e.key === "Escape")     close();
    if (e.key === "ArrowLeft")  prev();
    if (e.key === "ArrowRight") next();
  });

  lightbox.addEventListener("touchstart", e => {
    touchStartX = e.touches[0].clientX;
    touchDeltaX = 0;
  }, { passive: true });

  lightbox.addEventListener("touchmove", e => {
    touchDeltaX = e.touches[0].clientX - touchStartX;
  }, { passive: true });

  lightbox.addEventListener("touchend", () => {
    if (touchDeltaX < -50) next();
    else if (touchDeltaX > 50) prev();
    touchDeltaX = 0;
  });

  // reveal animation
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>