---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import H2 from '@components/ui/H2.astro';
import Tag from '@components/ui/Tag.astro';
import ObjectCard from '@components/ui/ObjectCard.astro';
import { getCollection, getEntry, getEntries, render, type CollectionEntry } from 'astro:content';

interface Props {
  material: CollectionEntry<"materials">
}

export async function getStaticPaths() {
  const allMaterials = await getCollection('materials');
  return allMaterials.map(material => ({
    params: { slug: material.id },
    props: { material },
  }));
}

const { material } = Astro.props;
const { Content } = await render(material);

const woodType = await getEntry(material.data.woodType)
const materialType = await getEntry(material.data.materialType)
const relatedObjects = await getEntries(material.data.relatedObjects)
---

<Layout
  pageTitle={material.data.metaTitle}
  pageDescription={material.data.metaDescription}
  ogImage={material.data.coverImage}
>
  <article>
    <Hero
      title={material.data.title}
      excerpt={material.data.excerpt}
      img={material.data.heroImage}
    />
    <div class="px-2 lg:px-4 text-foreground mt-8 mb-8">
      <div class="max-w-7xl flex flex-col items-center mx-auto gap-10 lg:gap-18">
  
        <div class="w-full">
  
          <!-- tag-list -->
          <div class="flex flex-wrap justify-center gap-2 mb-5 h-fit">
            <Tag 
              href=`/materials?type=${materialType.id}` 
              tag={materialType.data.title}
            />
            {woodType.data.title !== 'разные-породы' && (
              <Tag 
                href={`/materials?wood=${woodType.id}`}
                tag={woodType.data.title}
              />
            )}
          </div>
  
          <!-- mat-layout -->
          <div class="block gap-12 items-start">
  
            <!-- mat-main -->
            <div class="flex flex-col gap-8">
  
              <!-- sect: О материале -->
              <section class="flex flex-col gap-4 items-center">
                <H2 title="О материале"/>
                <div class="flex flex-col gap-2 w-full">
                  {material.data.description.split('\n\n').map((p) =>
                    p.trim() && <p class="">{p.trim()}</p>
                  )}
                  <div class=" text-foreground flex flex-col gap-2">
                    <Content />
                  </div>
                </div>
              </section>
  
              <div class="flex flex-col md:flex-row gap-4">
                <!-- sect: Особенности -->
                <section class="flex flex-col gap-4 flex-2">
                  <H2 title="Особенности материала"/>
                  <ul class="list-none flex flex-col gap-3">
                    {material.data.advantages.map((adv) => (
                      <li class="flex gap-3 items-center text-[0.93rem]  leading-normal">
                        <svg
                          width="18"
                          height="18"
                          viewBox="0 0 18 18"
                          fill="none"
                          aria-hidden="true"
                          class="shrink-0 text-line mt-[0.05rem]"
                        >
                          <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.5"/>
                          <path d="M5.5 9.5L8 12L12.5 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span>{adv}</span>
                      </li>
                    ))}
                  </ul>
                </section>
    
                <!-- sect: Применение -->
                <section class="flex flex-col gap-4 flex-1">
                  <H2 title="Область применения"/>
                  <div class="">
                    <p class="m-0 ">{material.data.application}</p>
                  </div>
                </section>
              </div>
              {relatedObjects.length > 0 && (
                <section class="flex flex-col gap-8">
                  <H2 title="Где использовали:"/>
                  <ul class="grid gap-2 md:gap-5
                             grid-cols-1 
                             xs:grid-cols-2 
                             sm:grid-cols-3 ">
                    {relatedObjects.map(rel => <ObjectCard object={rel}/>)}
                  </ul>
                </section>
              )}
            </div>
          </div>
  
        </div>
  
      </div>
    </div>
  </article>
</Layout>