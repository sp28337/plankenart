---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import AboutBlock from '../components/ui/AboutBlock.astro';
import CatalogBlock from '../components/ui/CatalogBlock.astro';
import heroImg from '../images/tmp/hero.png';

---

<Layout
	pageTitle="Обработка погонажных изделий различных пород древесины под ключ"
  pageDescription="Шлифовка древесины на проф-оборудовании, защита натуральными составами — масло, лазурь, краска"
>
	<main class="w-full">
		<Hero 
			title={["Монтаж и обработка планкена", "в Нижнем Новгороде"]} 
			variant="home"
			img={heroImg}
		/>
		<div class="px-2 lg:px-4 text-foreground flex flex-col items-center mt-8 mb-8 gap-8 md:gap-12">
			<AboutBlock/>
			<CatalogBlock/>
		</div>
	</main>
</Layout>
