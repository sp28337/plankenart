---
import Layout from "@layouts/Layout.astro";
import Hero from "@components/Hero.astro";
import FeedbackForm from "@components/FeedbackForm.astro";
import AboutBlock from "@components/ui/AboutBlock.astro";
import MaterialsBlock from "@components/ui/MaterialsBlock.astro";
import ServiceBlock from "@components/Services.astro";
import heroImg from "@assets/objects/naves-barbekyu-zona/hero.jpg";
import heroImgMobile from "@assets/objects/naves-barbekyu-zona/hero-mobile.jpg";
import FAQ from "@components/ui/FAQ.astro";
import NumbersBlock from "@components/ui/NumbersBlock.astro";
import ObjectsBlock from "@components/ui/ObjectsBlock.astro";
import OilsBlock from "@components/ui/OilsBlock.astro";
import DiscountSlider from "@components/ui/DiscountSlider.astro";
import PartnersBlock from "@components/ui/PartnersBlock.astro";
import H2 from "@components/ui/H2.astro";
import WorkSteps from "@components/ui/WorkSteps.astro";
---

<Layout
  pageTitle="Профессиональная шлифовка и покрытие маслом OSMO в Нижнем Новгороде"
  pageDescription="Восстанавливаем фасады, террасы и другие деревянные поверхности в Нижнем Новгороде. Защита, долговечность и премиальный результат."
>
  <Hero
    title={"Профессиональная шлифовка и покрытие маслом OSMO"}
    excerpt={"Восстанавливаем и защищаем деревянные фасады, террасы в Нижнем Новгороде"}
    img={heroImg}
    imgMobile={heroImgMobile}
  />
  <div class="px-2 lg:px-4 text-foreground mt-8">
    <div
      class="max-w-7xl flex flex-col items-center mx-auto gap-10 md:gap-18 lg:gap-22"
    >
      <AboutBlock />
      <NumbersBlock />
      <WorkSteps short={true}/>
      <ServiceBlock />
      <ObjectsBlock />
      <MaterialsBlock />
      <OilsBlock />
      <section
        id="contact"
        class="flex flex-col gap-6 md:gap-10 lg:gap-14 w-full items-center"
      >
        <H2 id="contact-heading" title="Обратная связь" />
        <p class="text-foreground/70 text-sm md:text-[1.05rem] leading-relaxed w-2/3 text-center">
          Сообщите площадь обработки, породу и артикул масла — расчёт пришлём за несколько часов. Если с артикулом не определились, поможем выбрать.
        </p>
        <div
          class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 w-full max-w-7xl mx-auto items-stretch"
        >
          <FeedbackForm type="test" />
          <FeedbackForm type="calc" />
        </div>
      </section>
      <DiscountSlider />
      <FAQ />
      <PartnersBlock />
    </div>
  </div>
</Layout>
