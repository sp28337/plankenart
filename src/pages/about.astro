---
import Layout from "@layouts/Layout.astro";
import Hero from "@components/Hero.astro";
import heroImg from "@assets/objects/naves-barbekyu-zona/2.jpg";
import heroImgMobile from "@assets/objects/naves-barbekyu-zona/2.jpg";
import about1 from "@assets/objects/avtonomnaya-barbekyu-zona/8-hero-mobile.jpg";
import about2 from "@assets/objects/banya-norvezhskiy-zamok/6.jpg";
import FAQ from "@components/ui/FAQ.astro";
import AboutContentBlock from "@components/ui/AboutContentBlock.astro";
import NumbersBlock from "@components/ui/NumbersBlock.astro";
import AdvantagesBlock from "@components/ui/AdvantagesBlock.astro";
import DiscountSlider from "@components/ui/DiscountSlider.astro";
import PartnersBlock from "@components/ui/PartnersBlock.astro";

const content = {
  block1: {
    h2: ["Мы не просто обрабатываем дерево —", "мы раскрываем его характер"],
    p: "ПланкенАрт — компания из Нижнего Новгорода, специализирующаяся на профессиональной обработке древесины и строительстве под ключ. Мы выполняем шлифовку, покрытие маслами OSMO, монтаж фасадов из планкена, устройство террас и строительство бань.\n\nКаждое изделие проходит двухэтапную шлифовку на профессиональном оборудовании, после чего обрабатывается натуральными маслами в два слоя. Такая технология защищает древесину изнутри: без плёнки, без растрескивания и без необходимости частого обслуживания.",
    img: about1,
  },

  block2: {
    h2: "Опыт, который формирует качество",
    p: "Мы начинали с возведения срубов и каркасных домов, постепенно расширяя экспертизу в области деревянного строительства и отделки. За более чем 10 лет реализовано свыше 100 проектов: бани в норвежском стиле, фахверковые дома, каркасные конструкции, барбекю-зоны и вентилируемые фасады из лиственницы и термоясеня.\n\nПрактический опыт позволяет нам точно подбирать материалы, технологии обработки и решения для долговечной эксплуатации древесины в любом проекте.",
    img: about2,
  },
};
---

<Layout
  pageTitle="О компании ПланкенАрт — деревянные фасады и строения в Нижнем Новгороде"
  pageDescription="ПланкенАрт — профессиональная шлифовка и покрытие древесины маслами OSMO, монтаж фасадов из планкена, строительство бань и беседок под ключ в Нижнем Новгороде."
  ogImg={heroImg.src}
>
  <Hero
    title="О компании ПланкенАрт"
    excerpt="Шлифовка, покрытие маслом OSMO и монтаж деревянных фасадов, террас и строений под ключ в Нижнем Новгороде"
    img={heroImg}
    imgMobile={heroImgMobile}
  />
  <div class="px-2 lg:px-4 text-foreground mt-8">
    <div
      class="max-w-7xl flex flex-col items-center mx-auto gap-10 md:gap-18 lg:gap-22"
    >
      <AboutContentBlock
        title={content.block1.h2}
        content={content.block1.p}
        img={content.block1.img}
      />
      <NumbersBlock />
      <AboutContentBlock
        title={content.block2.h2}
        content={content.block2.p}
        img={content.block2.img}
        direction="reversed"
      />
      <AdvantagesBlock />
      <FAQ />
      <DiscountSlider />
      <PartnersBlock />
    </div>
  </div>
</Layout>
