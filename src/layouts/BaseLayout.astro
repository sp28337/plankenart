---
import '../styles/global.css';
import { Font } from 'astro:assets';
interface Props {
  pageDescription: string,
  pageTitle: string,
  ogImg?: string,
}

const { 
  pageDescription,
  pageTitle,
  ogImg = "https://plankenart.sp28337.site/og-image.png",
} = Astro.props;

const siteUrl = 'https://plankenart.sp28337.site';
const canonicalURL = new URL(Astro.url.pathname + Astro.url.search, siteUrl);
const isBlogPost = Astro.url.pathname.startsWith('/objects/') || Astro.url.pathname.startsWith('/materials/');
const ogType = isBlogPost ? 'article' : 'website';
const fullOgImage = new URL(ogImg, Astro.site).pathname;
---
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content="ПланкенАрт" />
    <meta name="description" content={pageDescription} />

    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="apple-mobile-web-app-title" content="ПланкенАрт" />

    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <title>{pageTitle}</title>
    
    <Font cssVariable="--font-manrope" preload />
    <Font cssVariable="--font-inter" preload />
  </head>

  <body class="bg-html mx-auto font-manrope text-white">
    <slot />
  </body>
</html>