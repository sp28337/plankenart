import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';


const { pageTitle, pageDescription } = Astro.props;
---
<BaseLayout
  pageTitle={pageTitle}
  pageDescription={pageDescription}
>
	<Header/>
  <slot />
  <Footer/>
</BaseLayout>